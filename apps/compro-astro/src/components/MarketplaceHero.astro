---
interface Props {
	heroDesktop?: string;
	heroMobile?: string;
}

const {
	heroDesktop = '/marketplace/baju 1.webp',
	heroMobile = '/marketplace/baju 2.webp',
} = Astro.props as Props;
---

<section class="relative w-full mb-10 md:mb-16 overflow-hidden">
	<picture>
		<source media="(min-width: 768px)" srcset={heroDesktop} />
		<source media="(max-width: 767px)" srcset={heroMobile} />
		<img
			src={heroDesktop}
			alt="Avenue Collective New Season Collection 2026"
			class="w-full h-[75vh] md:h-[85vh] object-cover animate-kenburns"
			loading="eager"
			decoding="async"
			onerror="this.onerror=null; this.src='/marketplace/baju 1.webp';"
		/>
	</picture>

	<div class="absolute inset-0 bg-gradient-to-t from-black/30 via-black/5 to-transparent"></div>

	<div class="absolute bottom-8 md:bottom-12 left-1/2 -translate-x-1/2 text-center">
		<h1 class="animate-fade-up-1 text-white text-3xl md:text-6xl font-light tracking-widest mb-4 md:mb-6 drop-shadow-lg">
			AVENUE COLLECTIVE
		</h1>
		<a
			href="#products"
			class="animate-fade-up-2 inline-block px-6 md:px-8 py-2.5 md:py-3 border border-white text-white text-xs md:text-sm tracking-[0.2em] hover:bg-white hover:text-black transition-all duration-300"
		>
			SHOP NOW
		</a>
	</div>
</section>

<style is:global>
	@keyframes kenburns {
		0% { transform: scale(1) translate(0, 0); }
		100% { transform: scale(1.03) translate(-0.5%, -0.5%); }
	}

	.animate-kenburns {
		animation: kenburns 20s ease-in-out infinite alternate;
		will-change: transform;
	}

	@keyframes fadeUp {
		from { opacity: 0; transform: translateY(20px); }
		to { opacity: 1; transform: translateY(0); }
	}

	.animate-fade-up-1 { animation: fadeUp 0.8s ease-out 0.3s both; }
	.animate-fade-up-2 { animation: fadeUp 0.8s ease-out 0.6s both; }

	@keyframes fadeInStagger {
		from { opacity: 0; transform: translateX(-15px); }
		to { opacity: 1; transform: translateX(0); }
	}

	.animate-featured-stagger {
		animation: fadeInStagger 0.8s ease-out both;
	}

	@media (prefers-reduced-motion: reduce) {
		.animate-kenburns, .animate-fade-up-1, .animate-fade-up-2, .animate-featured-stagger {
			animation: none;
		}
	}
</style>
