---
type Props = {
	name?: string;
	avatar?: string;
	role?: string;
	email?: string;
};

const {
	name = 'Rizal Prananda',
	avatar = 'https://i.pravatar.cc/40',
	role = 'Administrator',
	email = ''
} = Astro.props as Props;
---

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

<div data-navbar-auth="user" class="relative hidden [font-family:Inter,ui-sans-serif,system-ui,-apple-system,Segoe_UI,Roboto,Helvetica,Arial]">
	<button
		type="button"
		data-navbar-auth="toggle"
		class="group inline-flex h-10 items-center gap-3 rounded-full border border-gray-200/80 bg-white/80 pl-1 pr-3 text-sm font-semibold text-black shadow-sm backdrop-blur-sm transition hover:border-gray-300 hover:shadow-md active:scale-95 dark:border-gray-700 dark:bg-gray-800/80 dark:text-gray-200"
		aria-haspopup="menu"
		aria-expanded="false"
	>
		<span class="relative grid size-8 shrink-0 place-items-center">
			<span data-navbar-auth="avatar" class="grid size-8 overflow-hidden rounded-full ring-2 ring-white dark:ring-gray-900">
				<img src={avatar} alt={name} class="h-full w-full object-cover bg-gray-100" />
			</span>
			<span class="absolute -bottom-0.5 -right-0.5 h-3 w-3 rounded-full bg-emerald-500 ring-2 ring-white dark:ring-gray-900"></span>
		</span>

		<span data-navbar-auth="name" class="hidden max-w-[12rem] truncate sm:block">{name}</span>

		<svg
			data-profile-dropdown="chevron"
			class="h-4 w-4 text-gray-500 transition-transform duration-200 dark:text-gray-300"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
		>
			<path d="M6 9l6 6 6-6" />
		</svg>
	</button>

	<div
		data-profile-dropdown="menu"
		data-navbar-auth="menu"
		class="absolute right-0 top-12 w-64 origin-top-right overflow-hidden rounded-2xl border border-gray-100 bg-white/95 shadow-xl shadow-gray-200/50 backdrop-blur-xl transition duration-200 ease-out [transform:translateZ(0)] opacity-0 scale-95 invisible pointer-events-none dark:border-gray-700 dark:bg-gray-800/95 dark:shadow-black/20"
		role="menu"
	>
		<div class="p-4">
			<div class="flex items-center gap-3">
				<div class="grid size-10 shrink-0 overflow-hidden rounded-full ring-2 ring-white dark:ring-gray-900">
					<img data-navbar-auth="avatarMenuImg" src={avatar} alt={name} class="h-full w-full object-cover bg-gray-100" />
				</div>
				<div class="min-w-0">
					<div data-navbar-auth="menuName" class="truncate text-sm font-semibold text-gray-900 dark:text-gray-100">{name}</div>
					{email ? <div class="mt-0.5 truncate text-xs text-gray-500 dark:text-gray-400">{email}</div> : null}
				</div>
			</div>
		</div>

		<div class="h-px bg-gradient-to-r from-transparent via-gray-200 to-transparent dark:via-gray-700"></div>

		<div class="p-2">
			<a
				href="/ProfilPelanggan"
				class="group flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm font-medium text-gray-700 transition hover:bg-gray-50 hover:text-[#1A56DB] dark:text-gray-200 dark:hover:bg-gray-700/50 dark:hover:text-blue-400"
				role="menuitem"
			>
				<svg class="h-5 w-5 text-gray-400 transition group-hover:text-[#1A56DB] dark:text-gray-400 dark:group-hover:text-blue-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
					<circle cx="12" cy="7" r="4" />
				</svg>
				<span class="flex-1">Lihat Profil</span>
				<svg class="h-4 w-4 text-gray-400 transition group-hover:translate-x-0.5 group-hover:text-[#1A56DB] dark:text-gray-400 dark:group-hover:text-blue-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path d="M9 18l6-6-6-6" />
				</svg>
			</a>

			<a
				href="/PesananSaya?menu=pesanan"
				class="group mt-1 flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm font-medium text-gray-700 transition hover:bg-gray-50 hover:text-[#1A56DB] dark:text-gray-200 dark:hover:bg-gray-700/50 dark:hover:text-blue-400"
				role="menuitem"
			>
				<svg class="h-5 w-5 text-gray-400 transition group-hover:text-[#1A56DB] dark:text-gray-400 dark:group-hover:text-blue-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path d="M6 2h12l3 7-4 12H7L3 9l3-7Z" />
					<path d="M3 9h18" />
					<path d="M9 13h6" />
				</svg>
				<span class="flex-1">Pesanan Saya</span>
				<svg class="h-4 w-4 text-gray-400 transition group-hover:translate-x-0.5 group-hover:text-[#1A56DB] dark:text-gray-400 dark:group-hover:text-blue-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path d="M9 18l6-6-6-6" />
				</svg>
			</a>

			<div class="my-2 h-px bg-gradient-to-r from-transparent via-gray-200 to-transparent dark:via-gray-700"></div>

			<button
				type="button"
				data-navbar-auth="logout"
				class="group flex w-full items-center gap-3 rounded-xl px-3 py-2.5 text-sm font-semibold text-red-600 transition hover:bg-red-50 dark:hover:bg-red-500/10"
				role="menuitem"
			>
				<svg class="h-5 w-5 text-red-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
					<path d="M16 17l5-5-5-5" />
					<path d="M21 12H9" />
				</svg>
				<span class="flex-1 text-left">Logout</span>
				<svg class="h-4 w-4 text-red-400 transition group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<path d="M9 18l6-6-6-6" />
				</svg>
			</button>
		</div>
	</div>
</div>

<script is:inline data-astro-rerun>
	(function () {
		const root = document.querySelector('[data-navbar-auth="user"]');
		if (!root) return;

		const btn = root.querySelector('[data-navbar-auth="toggle"]');
		const menu = root.querySelector('[data-profile-dropdown="menu"]');
		const chevron = root.querySelector('[data-profile-dropdown="chevron"]');

		if (!btn || !menu) return;

		const close = () => {
			menu.classList.add('invisible', 'pointer-events-none', 'opacity-0', 'scale-95');
			menu.classList.remove('opacity-100', 'scale-100');
			btn.setAttribute('aria-expanded', 'false');
			if (chevron) chevron.classList.remove('rotate-180');
		};

		const open = () => {
			menu.classList.remove('invisible', 'pointer-events-none', 'opacity-0', 'scale-95');
			menu.classList.add('opacity-100', 'scale-100');
			btn.setAttribute('aria-expanded', 'true');
			if (chevron) chevron.classList.add('rotate-180');
		};

		const isOpen = () => btn.getAttribute('aria-expanded') === 'true';

		btn.addEventListener('click', (e) => {
			e.preventDefault();
			if (isOpen()) close();
			else open();
		});

		document.addEventListener('mousedown', (e) => {
			if (!root.contains(e.target)) close();
		});

		window.addEventListener('keydown', (e) => {
			if (e.key === 'Escape') close();
		});
	})();
</script>
