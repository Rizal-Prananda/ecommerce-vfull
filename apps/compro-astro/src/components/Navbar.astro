---
import NavbarMenu from './NavbarMenu';
import ProfileDropdown from './ProfileDropdown.astro';
import CartButton from './CartButton.astro';

type Props = {
	variant?: 'default' | 'auth';
};

const items = [
	{ label: 'Home', href: '#home' },
	{ label: 'About', href: '#about' },
	{ label: 'Testimoni', href: '#testimoni' },
	{ label: 'Rekomendasi', href: '#rekomendasi' }
];

const marketplaceHref = '/marketplace';

const { variant = 'default' } = Astro.props as Props;

const pathname = Astro.url.pathname;
const resolveHref = (href: string) => {
	if (!href.startsWith('#')) return href;
	return pathname === '/' ? href : `/${href}`;
};

const navItems = items.map((x) => ({ ...x, href: resolveHref(x.href) }));
---

<header
	transition:persist
	class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-zinc-100"
>
	<div class="mx-auto flex w-full max-w-6xl items-center justify-between gap-4 px-4 py-3">
		<a href="/" class="flex items-center gap-2 font-semibold tracking-tight">
			<span class="grid size-9 place-items-center rounded-2xl bg-black text-white">R</span>
			<span class="text-black">Rizal Studio</span>
		</a>

		{
			variant === 'auth' ? (
				<div id="navbar-auth-actions" class="flex items-center gap-2">
					<!-- Tombol default (sebelum JS cek localStorage.user) -->
					<a
						data-navbar-auth="login"
						href="/login"
						class="inline-flex h-10 items-center justify-center rounded-2xl border border-gray-200 bg-white px-4 text-sm font-semibold text-black hover:bg-gray-50"
					>
						Login
					</a>
					<a
						data-navbar-auth="register"
						href="/register"
						class="inline-flex h-10 items-center justify-center rounded-2xl bg-black px-4 text-sm font-semibold text-white hover:bg-gray-900"
					>
						Daftar
					</a>

					<!-- Area user login (disembunyikan dulu, nanti JS nyalain kalau ada localStorage.user) -->
					<CartButton />
					<ProfileDropdown />
				</div>
			) : (
				<>
					<nav class="hidden items-center gap-6 text-sm font-medium text-gray-600 md:flex" aria-label="Primary">
						{
							navItems.map((item) => (
								<a href={item.href} class="hover:text-black">
									{item.label}
								</a>
							))
						}
						<a href={marketplaceHref} class="hover:text-black">Marketplace</a>
					</nav>

					<div id="navbar-auth-actions" class="hidden items-center gap-2 md:flex">
						<!-- Tombol default (sebelum JS cek localStorage.user) -->
						<a
							data-navbar-auth="login"
							href="/login"
							class="inline-flex h-10 items-center justify-center rounded-2xl border border-gray-200 bg-white px-4 text-sm font-semibold text-black hover:bg-gray-50"
						>
							Login
						</a>
						<a
							data-navbar-auth="register"
							href="/register"
							class="inline-flex h-10 items-center justify-center rounded-2xl bg-black px-4 text-sm font-semibold text-white hover:bg-gray-900"
						>
							Daftar
						</a>

						<!-- Area user login (disembunyikan dulu, nanti JS nyalain kalau ada localStorage.user) -->
						<CartButton />
						<ProfileDropdown />
					</div>

					<div id="navbar-react" class="md:hidden">
						<NavbarMenu client:load items={navItems} marketplaceHref={marketplaceHref} />
					</div>
				</>
			)
		}
	</div>

	{
		variant === 'auth' ? null : (
			<details id="navbar-nojs" class="hidden md:hidden border-t border-gray-200 bg-white/90 backdrop-blur">
		<summary class="flex cursor-pointer select-none items-center justify-between px-4 py-3 text-sm font-semibold text-slate-900">
			Menu
			<span aria-hidden="true">▾</span>
		</summary>
		<nav class="grid gap-1 px-4 pb-4 text-sm font-medium text-slate-700" aria-label="Mobile">
			{
				navItems.map((item) => (
					<a href={item.href} class="rounded-xl px-3 py-2 hover:bg-slate-50">
						{item.label}
					</a>
				))
			}
			<a href={marketplaceHref} class="rounded-xl px-3 py-2 hover:bg-slate-50">Marketplace</a>

			<div class="mt-2 grid grid-cols-2 gap-2">
				<a
					href="/login"
					class="inline-flex h-10 items-center justify-center rounded-2xl border border-gray-200 bg-white px-4 text-sm font-semibold text-black hover:bg-gray-50"
				>
					Login
				</a>
				<a
					href="/register"
					class="inline-flex h-10 items-center justify-center rounded-2xl bg-black px-4 text-sm font-semibold text-white hover:bg-gray-900"
				>
					Daftar
				</a>
			</div>
		</nav>
	</details>
		)
	}

	<script is:inline data-astro-rerun>
		document.getElementById('navbar-nojs')?.classList.add('hidden');
	</script>

	<script is:inline data-astro-rerun>
		// Navbar auth state (Login/Daftar vs User dropdown)
		// Sumber login: localStorage key "user" -> { name, avatarUrl }
		(function () {
			const root = document.getElementById('navbar-auth-actions');
			if (!root) return;

			const elLogin = root.querySelector('[data-navbar-auth="login"]');
			const elRegister = root.querySelector('[data-navbar-auth="register"]');
			const elUserWrap = root.querySelector('[data-navbar-auth="user"]');
			const elToggle = root.querySelector('[data-navbar-auth="toggle"]');
			const elAvatar = root.querySelector('[data-navbar-auth="avatar"]');
			const elAvatarMenuImg = root.querySelector('[data-navbar-auth="avatarMenuImg"]');
			const elName = root.querySelector('[data-navbar-auth="name"]');
			const elMenuName = root.querySelector('[data-navbar-auth="menuName"]');
			const elLogout = root.querySelector('[data-navbar-auth="logout"]');

			const setVisible = (el, visible) => {
				if (!el) return;
				if (visible) {
					el.classList.remove('hidden');
					el.removeAttribute('hidden');
					el.style.display = '';
				} else {
					el.classList.add('hidden');
					el.setAttribute('hidden', 'true');
					el.style.display = 'none';
				}
			};

			const readUser = () => {
				try {
					const raw = window.localStorage.getItem('user');
					if (!raw) return null;
					const obj = JSON.parse(raw);
					const name = String(obj?.name ?? '').trim();
					const avatarUrl = String(obj?.avatarUrl ?? '').trim();
					if (!name) return null;
					return { name, avatarUrl };
				} catch {
					return null;
				}
			};

			const applyLoggedOut = () => {
				setVisible(elLogin, true);
				setVisible(elRegister, true);
				setVisible(elUserWrap, false);
				if (elToggle) elToggle.setAttribute('aria-expanded', 'false');
			};

			const applyUser = (user) => {
				if (!user || !elLogin || !elRegister || !elUserWrap || !elName || !elMenuName) return;
				setVisible(elLogin, false);
				setVisible(elRegister, false);
				setVisible(elUserWrap, true);
				elName.textContent = user.name;
				elMenuName.textContent = user.name;

				// Avatar: pakai image kalau ada url, kalau tidak pakai inisial.
				if (elAvatar) {
					if (user.avatarUrl) {
						const img = document.createElement('img');
						img.src = user.avatarUrl;
						img.alt = user.name;
						img.className = 'h-full w-full object-cover bg-gray-100';
						elAvatar.textContent = '';
						elAvatar.appendChild(img);
					} else {
						elAvatar.textContent = String(user.name).trim().slice(0, 1).toUpperCase() || 'U';
					}
				}

				if (elAvatarMenuImg && user.avatarUrl) {
					elAvatarMenuImg.setAttribute('src', user.avatarUrl);
					elAvatarMenuImg.setAttribute('alt', user.name);
				}
			};

			const refreshAuthUi = () => {
				// Render state (default: Login/Daftar tampil)
				const user = readUser();
				if (user) {
					applyUser(user);
					// Kalau yang tersimpan masih email, coba refresh dari API biar jadi nama lengkap.
					const token = window.localStorage.getItem('token_pelanggan') || '';
					const pelangganId = window.localStorage.getItem('id_pelanggan') || '';
					const shouldRefreshName = String(user.name).includes('@') || /^pelanggan\s*#/i.test(String(user.name));
					if (token && shouldRefreshName) {
						fetch('/api/user', {
							headers: {
								Authorization: `Bearer ${token}`,
								...(pelangganId ? { 'X-Pelanggan-Id': pelangganId } : {})
							}
						})
							.then((r) => r.json().catch(() => null))
							.then((j) => {
								const name = String(j?.data?.nama_lengkap ?? '').trim();
								const avatarUrl = String(j?.data?.avatar ?? '').trim();
								if (!name) return;
								try {
									window.localStorage.setItem('user', JSON.stringify({ name, avatarUrl }));
								} catch {}
								applyUser({ name, avatarUrl });
							})
							.catch(() => {});
					}
					return;
				}

				applyLoggedOut();

				// Fallback: kalau token_pelanggan ada (chat sudah login) tapi localStorage.user belum keisi,
				// ambil data user dari /api/user biar Navbar ikut update.
				const token = window.localStorage.getItem('token_pelanggan') || '';
				const pelangganId = window.localStorage.getItem('id_pelanggan') || '';
				if (!token) return;

				fetch('/api/user', {
					headers: {
						Authorization: `Bearer ${token}`,
						...(pelangganId ? { 'X-Pelanggan-Id': pelangganId } : {})
					}
				})
					.then((r) => r.json().catch(() => null))
					.then((j) => {
						const name = String(j?.data?.nama_lengkap ?? '').trim();
						const avatarUrl = String(j?.data?.avatar ?? '').trim();
						if (!name) return;
						try {
							window.localStorage.setItem('user', JSON.stringify({ name, avatarUrl }));
						} catch {}
						applyUser({ name, avatarUrl });
					})
					.catch(() => {});
			};

			refreshAuthUi();

			// Update UI kalau login/logout terjadi tanpa reload (misal via view transitions / partial navigation)
			window.addEventListener('user:changed', refreshAuthUi);
			window.addEventListener('focus', refreshAuthUi);

			// Logout: hapus localStorage.user lalu reload (sekalian bersihin token chat biar state konsisten)
			if (elLogout) {
				elLogout.addEventListener('click', () => {
					try {
						window.localStorage.removeItem('user');
						window.localStorage.removeItem('token_pelanggan');
						window.localStorage.removeItem('id_pelanggan');
					} catch {}
					const target = `${window.location.origin}/#home`;
					if (window.location.pathname === '/' && window.location.hash === '#home') {
						window.location.reload();
						return;
					}
					window.location.replace(target);
				});
			}
		})();
	</script>
</header>
