---
import NavbarMenu from './NavbarMenu';

const items = [
	{ label: 'Home', href: '#home' },
	{ label: 'About', href: '#about' },
	{ label: 'Testimoni', href: '#testimoni' },
	{ label: 'Rekomendasi', href: '#rekomendasi' }
];

const marketplaceHref = '/marketplace';
---

<header
	transition:persist
	class="sticky top-0 z-[9999] border-b border-slate-200/70 bg-white/75 backdrop-blur supports-[backdrop-filter]:bg-white/65"
>
	<div class="mx-auto flex w-full max-w-6xl items-center justify-between gap-4 px-4 py-3">
		<a href="#home" class="flex items-center gap-2 font-semibold tracking-tight">
			<span class="grid size-9 place-items-center rounded-2xl bg-blue-600 text-white shadow-sm">R</span>
			<span class="text-slate-900">Rizal Studio</span>
		</a>

		<nav class="hidden items-center gap-6 text-sm font-medium text-slate-600 md:flex" aria-label="Primary">
			{
				items.map((item) => (
					<a href={item.href} class="hover:text-slate-900">
						{item.label}
					</a>
				))
			}
			<a href={marketplaceHref} class="hover:text-slate-900">Marketplace</a>
		</nav>

		<div class="hidden items-center gap-2 md:flex">
			<a
				href="/login"
				class="inline-flex h-10 items-center justify-center rounded-2xl border border-slate-200 bg-white px-4 text-sm font-semibold text-slate-900 shadow-sm hover:bg-slate-50"
			>
				Login
			</a>
			<a
				href="/register"
				class="inline-flex h-10 items-center justify-center rounded-2xl bg-blue-600 px-4 text-sm font-semibold text-white shadow-sm hover:bg-blue-700"
			>
				Daftar
			</a>
		</div>

		<div id="navbar-react" class="md:hidden">
			<NavbarMenu client:load items={items} marketplaceHref={marketplaceHref} />
		</div>
	</div>

	<details id="navbar-nojs" class="hidden md:hidden border-t border-slate-200/70 bg-white/90 backdrop-blur">
		<summary class="flex cursor-pointer select-none items-center justify-between px-4 py-3 text-sm font-semibold text-slate-900">
			Menu
			<span aria-hidden="true">▾</span>
		</summary>
		<nav class="grid gap-1 px-4 pb-4 text-sm font-medium text-slate-700" aria-label="Mobile">
			{
				items.map((item) => (
					<a href={item.href} class="rounded-xl px-3 py-2 hover:bg-slate-50">
						{item.label}
					</a>
				))
			}
			<a href={marketplaceHref} class="rounded-xl px-3 py-2 hover:bg-slate-50">Marketplace</a>

			<div class="mt-2 grid grid-cols-2 gap-2">
				<a
					href="/login"
					class="inline-flex h-10 items-center justify-center rounded-2xl border border-slate-200 bg-white px-4 text-sm font-semibold text-slate-900 shadow-sm hover:bg-slate-50"
				>
					Login
				</a>
				<a
					href="/register"
					class="inline-flex h-10 items-center justify-center rounded-2xl bg-blue-600 px-4 text-sm font-semibold text-white shadow-sm hover:bg-blue-700"
				>
					Daftar
				</a>
			</div>
		</nav>
	</details>

	<script is:inline>
		document.getElementById('navbar-nojs')?.classList.add('hidden');
	</script>
</header>
