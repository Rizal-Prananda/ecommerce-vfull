---
import Layout from '../layouts/Layout.astro';
import RegisterForm from '../components/RegisterForm';
---

<Layout title="Daftar">
	<main class="mx-auto w-full max-w-6xl px-4">
		<section class="grid gap-8 py-14 md:grid-cols-2 md:items-center md:py-20">
			<div class="flex flex-col gap-4">
				<h1 class="text-4xl font-semibold tracking-tight text-slate-900">Daftar</h1>
				<p class="text-sm leading-7 text-slate-600">
					Buat akun untuk mulai chat dan akses fitur marketplace.
				</p>
				<div class="text-sm text-slate-600">
					Sudah punya akun? <a class="font-semibold text-blue-700 hover:underline" href="/login">Login</a>
				</div>
			</div>

			<div class="rounded-[2.5rem] border border-slate-200 bg-white/85 p-8 shadow-sm backdrop-blur">
				<RegisterForm client:load />
			</div>
		</section>
	</main>
</Layout>
