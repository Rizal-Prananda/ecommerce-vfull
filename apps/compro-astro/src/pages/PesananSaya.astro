---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Pesanan Saya">
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

	<main class="bg-[#F8FAFC] text-gray-900">
		<div class="mx-auto w-full max-w-7xl px-4 py-8 [font-family:Inter,ui-sans-serif,system-ui,-apple-system,Segoe_UI,Roboto,Helvetica,Arial]">
			<div class="grid grid-cols-1 gap-6 lg:grid-cols-[280px_1fr]">
				<aside class="h-fit rounded-2xl border border-gray-100 bg-white p-6 shadow-sm">
					<div class="border-b border-gray-100 pb-5">
						<div class="flex items-center justify-between gap-3">
							<div class="flex items-center gap-3">
								<div class="relative">
									<div class="grid size-12 overflow-hidden rounded-full bg-gray-100 ring-2 ring-blue-50">
										<img data-orders="sidebarAvatar" src="https://ui-avatars.com/api/?name=User&background=000000&color=ffffff&size=128" alt="Avatar" class="h-full w-full object-cover" />
									</div>
								</div>
								<div class="min-w-0">
									<div data-orders="sidebarName" class="truncate text-sm font-semibold text-gray-900">User</div>
									<a href="/ProfilPelanggan?menu=akun" class="mt-0.5 inline-flex text-xs font-semibold text-[#1A56DB] transition-all hover:underline active:scale-95">Ubah Profil</a>
								</div>
							</div>
						</div>
					</div>

					<nav class="mt-4 grid gap-1" aria-label="Profil Menu">
						<a
							href="/ProfilPelanggan?menu=akun"
							data-orders-menu="akun"
							class="flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm font-medium transition-all"
						>
							<svg data-orders-icon="akun" class="h-5 w-5 text-gray-400 transition-all" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
								<circle cx="12" cy="7" r="4" />
							</svg>
							<span class="flex-1">Akun Saya</span>
						</a>
						<a
							href="/PesananSaya?menu=pesanan"
							data-orders-menu="pesanan"
							class="flex items-center gap-3 rounded-xl px-3 py-2.5 text-sm font-medium transition-all"
						>
							<svg data-orders-icon="pesanan" class="h-5 w-5 text-gray-400 transition-all" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
								<path d="M6 2h12l3 7-4 12H7L3 9l3-7Z" />
								<path d="M3 9h18" />
								<path d="M9 13h6" />
							</svg>
							<span class="flex-1">Pesanan Saya</span>
						</a>
					</nav>
				</aside>

				<section class="rounded-2xl border border-gray-100 bg-white p-8 shadow-sm">
					<div class="border-b border-gray-100 pb-5">
						<div class="text-xl font-semibold text-gray-900">Pesanan Saya</div>
						<div class="mt-1 text-sm text-gray-500">Daftar pesanan yang pernah kamu buat.</div>
					</div>

					<div class="mt-8">
						<div data-orders="empty" class="flex flex-col items-center justify-center py-20 text-center">
							<svg viewBox="0 0 24 24" class="h-16 w-16 text-gray-300" fill="none" stroke="currentColor" stroke-width="1.5">
								<path d="M6 2h12l3 7-4 12H7L3 9l3-7Z" />
								<path d="M3 9h18" />
								<path d="M9 13h6" />
							</svg>
							<div class="mt-4 text-base font-semibold text-gray-900">Belum ada pesanan</div>
							<div class="mt-1 text-sm text-gray-500">Pesanan kamu akan muncul di sini setelah checkout.</div>
						</div>

						<div data-orders="list" class="hidden space-y-3"></div>
					</div>
				</section>
			</div>
		</div>
	</main>

	<script is:inline data-astro-rerun>
		(function () {
			const menu = new URLSearchParams(window.location.search).get('menu') || 'pesanan';
			if (menu === 'akun') {
				window.location.replace('/ProfilPelanggan?menu=akun');
				return;
			}

			const akun = document.querySelector('[data-orders-menu="akun"]');
			const pesanan = document.querySelector('[data-orders-menu="pesanan"]');
			const styleActive = (el, icon) => {
				if (!el) return;
				el.classList.add('bg-[#EFF6FF]', 'text-[#1A56DB]', 'font-semibold');
				el.classList.remove('text-gray-600', 'hover:bg-gray-50', 'hover:text-gray-900');
				if (icon) {
					icon.classList.add('text-[#1A56DB]');
					icon.classList.remove('text-gray-400');
				}
			};
			const styleInactive = (el, icon) => {
				if (!el) return;
				el.classList.remove('bg-[#EFF6FF]', 'text-[#1A56DB]', 'font-semibold');
				el.classList.add('text-gray-600', 'hover:bg-gray-50', 'hover:text-gray-900');
				if (icon) {
					icon.classList.remove('text-[#1A56DB]');
					icon.classList.add('text-gray-400');
				}
			};
			styleInactive(akun, document.querySelector('[data-orders-icon="akun"]'));
			styleActive(pesanan, document.querySelector('[data-orders-icon="pesanan"]'));

			const getAuth = () => {
				const token = window.localStorage.getItem('token_pelanggan') || '';
				const id = window.localStorage.getItem('id_pelanggan') || '';
				return { token, id };
			};

			const setText = (sel, v) => {
				const el = document.querySelector(sel);
				if (el) el.textContent = v;
			};
			const setAvatar = (url) => {
				const img = document.querySelector('[data-orders="sidebarAvatar"]');
				if (img) img.setAttribute('src', url);
			};

			const loadUser = async () => {
				const auth = getAuth();
				if (!auth.token && !auth.id) return;
				const res = await fetch(auth.id ? `/api/user?id_pelanggan=${encodeURIComponent(String(auth.id))}` : '/api/user', {
					headers: {
						...(auth.token ? { Authorization: `Bearer ${auth.token}` } : {}),
						...(auth.id ? { 'X-Pelanggan-Id': auth.id } : {})
					}
				}).catch(() => null);
				const json = res ? await res.json().catch(() => null) : null;
				if (!res || !res.ok || !json?.ok) return;
				const name = String(json?.data?.nama_lengkap ?? '').trim() || 'User';
				const avatar = String(json?.data?.avatar ?? '').trim();
				setText('[data-orders="sidebarName"]', name);
				if (avatar) setAvatar(avatar);
			};

			const loadOrders = async () => {
				const auth = getAuth();
				const list = document.querySelector('[data-orders="list"]');
				const empty = document.querySelector('[data-orders="empty"]');
				if (!list || !empty) return;
				if (!auth.token && !auth.id) return;

				const res = await fetch('/api/orders', {
					headers: {
						...(auth.token ? { Authorization: `Bearer ${auth.token}` } : {}),
						...(auth.id ? { 'X-Pelanggan-Id': auth.id } : {})
					}
				}).catch(() => null);
				const json = res ? await res.json().catch(() => null) : null;
				const items = Array.isArray(json?.data) ? json.data : [];
				if (!items.length) {
					list.classList.add('hidden');
					empty.classList.remove('hidden');
					return;
				}

				const escapeHtml = (s) =>
					String(s ?? '')
						.replace(/&/g, '&amp;')
						.replace(/</g, '&lt;')
						.replace(/>/g, '&gt;')
						.replace(/"/g, '&quot;')
						.replace(/'/g, '&#039;');

				const statusBadgeClass = (raw) => {
					const s = String(raw || '').toUpperCase();
					if (['SUCCESS', 'PAID', 'DONE', 'COMPLETED', 'DELIVERED'].includes(s)) return 'bg-green-50 text-green-700';
					if (['CANCEL', 'CANCELED', 'CANCELLED', 'FAILED', 'REFUND'].includes(s)) return 'bg-red-50 text-red-700';
					return 'bg-amber-50 text-amber-700';
				};

				list.innerHTML = items
					.map((o) => {
						const no = escapeHtml(o?.order_no || `#${o?.id_order ?? ''}`);
						const statusRaw = String(o?.status || 'PENDING');
						const status = escapeHtml(statusRaw);
						const badge = statusBadgeClass(statusRaw);
						const total = Number(o?.total ?? 0);
						return (
							`<div class="rounded-xl border border-gray-100 bg-white p-4 transition hover:shadow-md">` +
								`<div class="flex items-start justify-between gap-3">` +
									`<div class="min-w-0">` +
										`<div class="truncate text-sm font-semibold text-gray-900">${no}</div>` +
										`<div class="mt-2 inline-flex items-center gap-2">` +
											`<span class="rounded-full px-3 py-1 text-xs font-medium ${badge}">` +
												`${status}` +
											`</span>` +
										`</div>` +
									`</div>` +
									`<div class="shrink-0 text-sm font-semibold text-gray-900">Rp ${total.toLocaleString('id-ID')}</div>` +
								`</div>` +
							`</div>`
						);
					})
					.join('');

				empty.classList.add('hidden');
				list.classList.remove('hidden');
			};

			void loadUser();
			void loadOrders();
		})();
	</script>
</Layout>
