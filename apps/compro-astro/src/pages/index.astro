---
import '../styles/global.css';
import Navbar from '../components/Navbar.jsx';

const CMS_URL = import.meta.env.PUBLIC_CMS_URL ?? 'http://127.0.0.1:8000';
---

<html lang="id" class="h-full">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>E-Commerce</title>
	</head>
	<body class="min-h-full">
		<Navbar client:load />

		<main class="mx-auto w-full max-w-6xl px-4">
			<section id="home" class="relative overflow-hidden py-14 md:py-20">
				<div class="grid gap-10 md:grid-cols-2 md:items-center">
					<div class="flex flex-col gap-6">
						<div
							class="inline-flex w-fit items-center gap-2 rounded-full border border-slate-200 bg-white/80 px-3 py-1 text-xs font-medium text-slate-700 shadow-sm"
						>
							<span class="inline-block size-2 rounded-full bg-[rgb(var(--accent))]"></span>
							Modern • Smooth • Responsive
						</div>
						<h1 class="text-4xl font-semibold leading-tight tracking-tight text-slate-900 md:text-5xl">
							Elevate your experience dengan desain modern yang rapi dan premium
						</h1>
						<p class="max-w-xl text-base leading-7 text-slate-600">
							Company profile 1 halaman (Home, About, Testimoni, Rekomendasi) dengan warna lembut,
							card blur, dan micro-interaction yang halus.
						</p>
						<div class="flex flex-col gap-3 sm:flex-row">
							<a
								href="#about"
								class="inline-flex h-12 items-center justify-center rounded-full bg-[rgb(var(--primary))] px-6 text-sm font-semibold text-white shadow-sm hover:brightness-95"
							>
								Lihat Profil
							</a>
							<a
								href={`${CMS_URL}/dashboard`}
								class="inline-flex h-12 items-center justify-center rounded-full border border-slate-200 bg-white px-6 text-sm font-semibold text-slate-900 shadow-sm hover:bg-slate-50"
							>
								Ke Dashboard CMS
							</a>
						</div>

						<div class="grid grid-cols-3 gap-3 pt-3">
							<div class="rounded-2xl border border-slate-200 bg-white/85 p-4 shadow-sm">
								<div class="text-2xl font-semibold tracking-tight">120+</div>
								<div class="text-xs font-medium text-slate-600">Project selesai</div>
							</div>
							<div class="rounded-2xl border border-slate-200 bg-white/85 p-4 shadow-sm">
								<div class="text-2xl font-semibold tracking-tight">4.9</div>
								<div class="text-xs font-medium text-slate-600">Rating rata-rata</div>
							</div>
							<div class="rounded-2xl border border-slate-200 bg-white/85 p-4 shadow-sm">
								<div class="text-2xl font-semibold tracking-tight">24/7</div>
								<div class="text-xs font-medium text-slate-600">Support cepat</div>
							</div>
						</div>
					</div>

					<div class="relative">
						<div
							class="absolute -inset-2 rounded-[2.5rem] bg-gradient-to-br from-blue-200/70 via-violet-200/50 to-amber-200/50 blur-2xl"
						>
						</div>
						<div
							class="relative rounded-[2.5rem] border border-slate-200 bg-white/85 p-5 shadow-sm backdrop-blur"
						>
							<div class="flex items-center justify-between gap-4 rounded-2xl bg-slate-50 p-4">
								<div class="flex items-center gap-3">
									<div class="size-11 rounded-2xl bg-slate-900"></div>
									<div class="flex flex-col">
										<div class="text-sm font-semibold text-slate-900">Discover Unrivaled Excellence</div>
										<div class="text-xs text-slate-600">Cari layanan & rekomendasi</div>
									</div>
								</div>
								<div class="hidden items-center gap-2 md:flex">
									<span class="rounded-full bg-white px-3 py-1 text-xs font-medium text-slate-600 shadow-sm"
										>Fast</span
									>
									<span class="rounded-full bg-white px-3 py-1 text-xs font-medium text-slate-600 shadow-sm"
										>Clean</span
									>
								</div>
							</div>

							<div class="mt-4 grid gap-3">
								<div class="flex items-center gap-3 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
									<div class="size-11 rounded-2xl bg-blue-100"></div>
									<div class="flex-1">
										<div class="text-sm font-semibold text-slate-900">Branding & Identitas</div>
										<div class="text-xs text-slate-600">Logo, guideline, template sosial media</div>
									</div>
									<div class="text-xs font-semibold text-[rgb(var(--primary))]">Detail</div>
								</div>
								<div class="flex items-center gap-3 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
									<div class="size-11 rounded-2xl bg-violet-100"></div>
									<div class="flex-1">
										<div class="text-sm font-semibold text-slate-900">Company Profile</div>
										<div class="text-xs text-slate-600">1 page modern + integrasi CMS</div>
									</div>
									<div class="text-xs font-semibold text-[rgb(var(--primary))]">Detail</div>
								</div>
								<div class="flex items-center gap-3 rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
									<div class="size-11 rounded-2xl bg-amber-100"></div>
									<div class="flex-1">
										<div class="text-sm font-semibold text-slate-900">Marketplace</div>
										<div class="text-xs text-slate-600">Catalog, search, kategori, CTA</div>
									</div>
									<div class="text-xs font-semibold text-[rgb(var(--primary))]">Detail</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<section id="about" class="py-12 md:py-16">
				<div class="grid gap-8 md:grid-cols-2 md:items-center">
					<div class="relative">
						<div class="absolute -inset-2 rounded-[2rem] bg-white/70 blur-xl"></div>
						<div
							class="relative overflow-hidden rounded-[2rem] border border-slate-200 bg-gradient-to-br from-slate-900 via-slate-800 to-slate-700 p-6 shadow-sm"
						>
							<div class="flex items-end justify-between gap-4">
								<div>
									<div class="text-xs font-medium text-slate-300">Our Story</div>
									<div class="mt-1 text-2xl font-semibold tracking-tight text-white">Rizal Studio</div>
									<div class="mt-2 max-w-sm text-sm leading-6 text-slate-200">
										Fokus bikin tampilan modern yang enak dilihat, cepat, dan gampang dikembangkan.
									</div>
								</div>
								<div class="grid size-14 place-items-center rounded-2xl bg-white/10 text-white">★</div>
							</div>
							<div class="mt-8 grid gap-3 md:grid-cols-2">
								<div class="rounded-2xl bg-white/10 p-4">
									<div class="text-sm font-semibold text-white">Quality</div>
									<div class="mt-1 text-xs leading-5 text-slate-200">
										Tipografi rapi, spacing konsisten, komponen reusable.
									</div>
								</div>
								<div class="rounded-2xl bg-white/10 p-4">
									<div class="text-sm font-semibold text-white">Integrity</div>
									<div class="mt-1 text-xs leading-5 text-slate-200">
										Proses jelas, struktur proyek bersih, siap produksi.
									</div>
								</div>
							</div>
						</div>
					</div>

					<div class="flex flex-col gap-5">
						<h2 class="text-2xl font-semibold tracking-tight text-slate-900">Tentang Layanan</h2>
						<p class="text-sm leading-7 text-slate-600">
							Web ini dibuat modern (gradient lembut + glass card), smooth scroll, dan siap terhubung ke CMS
							Laravel lewat API. Cocok untuk company profile, agency, atau brand personal.
						</p>
						<div class="grid gap-3 sm:grid-cols-2">
							<div class="rounded-2xl border border-slate-200 bg-white/85 p-4 shadow-sm">
								<div class="text-sm font-semibold text-slate-900">Desain Modern</div>
								<div class="mt-1 text-xs leading-5 text-slate-600">Card clean, shadow halus, layout rapi.</div>
							</div>
							<div class="rounded-2xl border border-slate-200 bg-white/85 p-4 shadow-sm">
								<div class="text-sm font-semibold text-slate-900">Performant</div>
								<div class="mt-1 text-xs leading-5 text-slate-600">Cepat dibuka, animasi ringan.</div>
							</div>
							<div class="rounded-2xl border border-slate-200 bg-white/85 p-4 shadow-sm">
								<div class="text-sm font-semibold text-slate-900">Terhubung CMS</div>
								<div class="mt-1 text-xs leading-5 text-slate-600">Data testimoni & rekomendasi dari API.</div>
							</div>
							<div class="rounded-2xl border border-slate-200 bg-white/85 p-4 shadow-sm">
								<div class="text-sm font-semibold text-slate-900">Siap Marketplace</div>
								<div class="mt-1 text-xs leading-5 text-slate-600">Marketplace dibuat di Next.js.</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<section id="testimoni" class="py-12 md:py-16">
				<div class="flex items-end justify-between gap-6">
					<div>
						<h2 class="text-2xl font-semibold tracking-tight text-slate-900">Voices of Trust</h2>
						<p class="mt-1 text-sm text-slate-600">Testimoni diambil dari CMS Laravel.</p>
					</div>
					<a
						href={`${CMS_URL}/dashboard`}
						class="hidden rounded-full border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-900 shadow-sm hover:bg-slate-50 md:inline-flex"
					>
						Kelola di CMS
					</a>
				</div>

				<div id="testiApp" class="mt-6" ng-app="testiApp" ng-controller="TestiCtrl as vm">
					<div class="grid gap-4 md:grid-cols-3">
						<div
							class="rounded-2xl border border-slate-200 bg-white/85 p-5 shadow-sm backdrop-blur"
							ng-repeat="t in vm.items"
						>
							<div class="flex items-center justify-between gap-3">
								<div class="flex items-center gap-3">
									<div class="grid size-10 place-items-center rounded-2xl bg-slate-900 text-sm font-semibold text-white">
										<span ng-bind="t.name.charAt(0)"></span>
									</div>
									<div class="leading-tight">
										<div class="text-sm font-semibold text-slate-900" ng-bind="t.name"></div>
										<div class="text-xs text-slate-600" ng-bind="t.role"></div>
									</div>
								</div>
								<div class="text-xs font-semibold text-amber-600" ng-bind="(t.rating || 0).toFixed(1)"></div>
							</div>
							<p class="mt-4 text-sm leading-7 text-slate-700" ng-bind="t.message"></p>
						</div>
					</div>

					<div class="mt-4 rounded-2xl border border-slate-200 bg-white/70 p-4 text-sm text-slate-600 shadow-sm">
						<span class="font-semibold text-slate-900">API:</span>
						<span class="font-mono text-xs">{CMS_URL}/api/testimonials</span>
					</div>
				</div>

				<script is:inline src="https://ajax.googleapis.com/ajax/libs/angularjs/1.8.3/angular.min.js"></script>
				<script is:inline define:vars={{ CMS_URL }}>
					(() => {
						const app = angular.module('testiApp', []);
						app.controller('TestiCtrl', function ($scope) {
							const vm = (this);
							vm.items = [];
							const apiUrl = `${CMS_URL.replace(/\/$/, '')}/api/testimonials`;
							fetch(apiUrl)
								.then((r) => r.json())
								.then((data) => {
									vm.items = Array.isArray(data?.data) ? data.data : [];
									if (!vm.items.length) {
										vm.items = [
											{ name: 'Client A', role: 'Founder', rating: 4.9, message: 'Desainnya modern, rapi, dan cepat.' },
											{ name: 'Client B', role: 'Marketing', rating: 4.8, message: 'Workflow enak, hasil sesuai ekspektasi.' },
											{ name: 'Client C', role: 'Owner', rating: 5.0, message: 'Tampilan premium dan responsif.' }
										];
									}
									$scope.$applyAsync();
								})
								.catch(() => {
									vm.items = [
										{ name: 'Client A', role: 'Founder', rating: 4.9, message: 'Desainnya modern, rapi, dan cepat.' },
										{ name: 'Client B', role: 'Marketing', rating: 4.8, message: 'Workflow enak, hasil sesuai ekspektasi.' },
										{ name: 'Client C', role: 'Owner', rating: 5.0, message: 'Tampilan premium dan responsif.' }
									];
									$scope.$applyAsync();
								});
						});

						setTimeout(() => {
							const el = document.getElementById('testiApp');
							if (el) angular.bootstrap(el, ['testiApp']);
						}, 0);
					})();
				</script>
			</section>

			<section id="rekomendasi" class="py-12 md:py-16">
				<div class="grid gap-6 md:grid-cols-2 md:items-end">
					<div>
						<h2 class="text-2xl font-semibold tracking-tight text-slate-900">Rekomendasi</h2>
						<p class="mt-1 text-sm text-slate-600">Pilihan layanan yang paling sering dipilih.</p>
					</div>
					<div class="flex gap-2 md:justify-end">
						<a
							href="http://localhost:3000"
							class="inline-flex h-11 items-center justify-center rounded-full border border-slate-200 bg-white px-5 text-sm font-semibold text-slate-900 shadow-sm hover:bg-slate-50"
						>
							Lihat Marketplace
						</a>
						<a
							href={`${CMS_URL}/dashboard`}
							class="inline-flex h-11 items-center justify-center rounded-full bg-slate-900 px-5 text-sm font-semibold text-white shadow-sm hover:bg-slate-800"
						>
							Kelola CMS
						</a>
					</div>
				</div>

				<div class="mt-6 grid gap-4 md:grid-cols-3" id="rekomWrap">
					<div class="rounded-2xl border border-slate-200 bg-white/85 p-5 shadow-sm backdrop-blur">
						<div class="text-xs font-semibold text-[rgb(var(--primary))]">Paket</div>
						<div class="mt-1 text-lg font-semibold text-slate-900">Company Profile Modern</div>
						<div class="mt-2 text-sm leading-7 text-slate-600">Landing 1 halaman + integrasi CMS + CTA.</div>
						<div class="mt-4 inline-flex rounded-full bg-slate-900 px-3 py-1 text-xs font-semibold text-white">Populer</div>
					</div>
					<div class="rounded-2xl border border-slate-200 bg-white/85 p-5 shadow-sm backdrop-blur">
						<div class="text-xs font-semibold text-[rgb(var(--primary))]">Paket</div>
						<div class="mt-1 text-lg font-semibold text-slate-900">Branding Starter</div>
						<div class="mt-2 text-sm leading-7 text-slate-600">Logo + guideline + template social media.</div>
						<div class="mt-4 inline-flex rounded-full bg-amber-500 px-3 py-1 text-xs font-semibold text-white">Best value</div>
					</div>
					<div class="rounded-2xl border border-slate-200 bg-white/85 p-5 shadow-sm backdrop-blur">
						<div class="text-xs font-semibold text-[rgb(var(--primary))]">Paket</div>
						<div class="mt-1 text-lg font-semibold text-slate-900">Marketplace Setup</div>
						<div class="mt-2 text-sm leading-7 text-slate-600">Catalog, kategori, search, dan listing produk.</div>
						<div class="mt-4 inline-flex rounded-full bg-violet-600 px-3 py-1 text-xs font-semibold text-white">New</div>
					</div>
				</div>

				<script is:inline define:vars={{ CMS_URL }}>
					(() => {
						const wrap = document.getElementById('rekomWrap');
						if (!wrap) return;
						const apiUrl = `${CMS_URL.replace(/\/$/, '')}/api/recommendations`;
						fetch(apiUrl)
							.then((r) => r.json())
							.then((json) => {
								const items = Array.isArray(json?.data) ? json.data : [];
								if (!items.length) return;
								wrap.innerHTML = items
									.slice(0, 3)
									.map((x, idx) => {
										const badge =
											idx === 0
												? 'bg-slate-900'
												: idx === 1
													? 'bg-amber-500'
													: 'bg-violet-600';
										const badgeText = idx === 0 ? 'Populer' : idx === 1 ? 'Best value' : 'New';
										return `
											<div class="rounded-2xl border border-slate-200 bg-white/85 p-5 shadow-sm backdrop-blur">
												<div class="text-xs font-semibold text-[rgb(var(--primary))]">${x.tag ?? 'Paket'}</div>
												<div class="mt-1 text-lg font-semibold text-slate-900">${x.title ?? ''}</div>
												<div class="mt-2 text-sm leading-7 text-slate-600">${x.description ?? ''}</div>
												<div class="mt-4 inline-flex rounded-full ${badge} px-3 py-1 text-xs font-semibold text-white">${badgeText}</div>
											</div>
										`;
									})
									.join('');
							})
							.catch(() => {});
					})();
				</script>
			</section>
		</main>

		<footer class="mt-10 border-t border-slate-200/70 bg-white/60">
			<div class="mx-auto flex w-full max-w-6xl flex-col gap-3 px-4 py-8 md:flex-row md:items-center md:justify-between">
				<div class="text-sm font-semibold text-slate-900">Rizal Studio</div>
				<div class="text-xs text-slate-600">Astro • AngularJS • Next.js • Laravel • TailwindCSS</div>
			</div>
		</footer>
	</body>
</html>
