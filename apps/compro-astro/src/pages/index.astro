---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Testimoni from '../components/Testimoni.astro';
import Rekomendasi from '../components/Rekomendasi.astro';
import Footer from '../components/Footer.astro';

const CMS_URL = import.meta.env.PUBLIC_CMS_URL ?? 'http://127.0.0.1:8001';
---

<Layout title="E-Commerce" withNavbar={false}>
	<style is:global>
		html { scroll-behavior: smooth; scroll-padding-top: 80px; }
	</style>

	<script is:inline>
		(() => {
			const html = document.documentElement;
			const prev = html.style.scrollBehavior;
			const hadHash = !!window.location.hash;
			html.style.scrollBehavior = 'auto';
			if (hadHash) document.body.style.visibility = 'hidden';
			window.addEventListener(
				'load',
				() => {
					html.style.scrollBehavior = prev || '';
					if (hadHash) document.body.style.visibility = '';
				},
				{ once: true }
			);
		})();
	</script>

	<Navbar />

	<main class="mx-auto w-full max-w-6xl px-4 pt-20">
		<Hero id="home" />
		<About CMS_URL={CMS_URL} />
		<Testimoni CMS_URL={CMS_URL} />
		<Rekomendasi CMS_URL={CMS_URL} />
	</main>

	<Footer />
</Layout>
