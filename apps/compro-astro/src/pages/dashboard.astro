---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Dashboard">
	<main class="mx-auto w-full max-w-6xl px-4 py-10">
		<div class="rounded-3xl border border-gray-200 bg-white/85 p-6 backdrop-blur">
			<h1 class="text-2xl font-bold tracking-tight text-black">Dashboard</h1>
			<p class="mt-2 text-sm leading-7 text-gray-600">
				Kamu sudah login. Halaman ini bisa kamu isi nanti untuk profil pelanggan, riwayat order, dan chat.
			</p>
			<div class="mt-5 flex flex-wrap gap-2">
				<a
					href="/marketplace"
					class="inline-flex h-10 items-center justify-center rounded-2xl border border-gray-200 bg-white px-4 text-sm font-semibold text-black hover:bg-gray-50"
				>
					Buka Marketplace
				</a>
				<a
					href="/"
					class="inline-flex h-10 items-center justify-center rounded-2xl bg-black px-4 text-sm font-semibold text-white hover:bg-gray-900"
				>
					Kembali ke Home
				</a>
			</div>
		</div>
	</main>
</Layout>

