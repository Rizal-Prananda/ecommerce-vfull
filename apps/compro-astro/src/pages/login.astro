---
import Layout from '../layouts/Layout.astro';
import LoginForm from '../components/LoginForm';
---

<Layout title="Login">
	<main class="mx-auto w-full max-w-6xl px-4">
		<section class="grid gap-8 py-14 md:grid-cols-2 md:items-center md:py-20">
			<div class="flex flex-col gap-4">
				<h1 class="text-4xl font-semibold tracking-tight text-slate-900">Login</h1>
				<p class="text-sm leading-7 text-slate-600">
					Masuk untuk mulai chat dan melanjutkan aktivitas marketplace.
				</p>
				<div class="text-sm text-slate-600">
					Belum punya akun? <a class="font-semibold text-blue-700 hover:underline" href="/register">Daftar</a>
				</div>
			</div>

			<div class="rounded-[2.5rem] border border-slate-200 bg-white/85 p-8 shadow-sm backdrop-blur">
				<LoginForm client:load />
			</div>
		</section>
	</main>
</Layout>
