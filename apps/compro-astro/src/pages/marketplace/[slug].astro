---
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';

type Product = {
	id: number;
	title: string;
	slug: string;
	category: string;
	price: number;
	price_formatted?: string;
	rating?: number;
	image_url?: string | null;
	stock?: number;
};

type ProductView = Product & {
	imageUrl: string;
	ratingValue: number;
};

const CMS_URL = import.meta.env.PUBLIC_CMS_URL ?? 'http://127.0.0.1:8001';
const slug = Astro.params.slug ?? '';
const idStr = slug.split('-')[0] ?? '';
const id = Number(idStr);

if (!Number.isInteger(id) || id <= 0) {
return Astro.redirect('/marketplace', 302);
}

let cmsError: string | null = null;
let product: Product | null = null;
let relatedProducts: ProductView[] = [];

const colors = ['Black', 'White', 'Grey', 'Ivory'];

function slugify(input: string) {
return input
.toLowerCase()
.trim()
.replace(/[^a-z0-9]+/g, '-')
.replace(/(^-|-$)/g, '');
}

function pickCategory(p: Product) {
	const v = String((p as any)?.category ?? '').trim();
	if (v !== '') return v;
	return 'Marketplace';
}

function ratingFrom(p: Product) {
const v = typeof p.rating === 'number' && Number.isFinite(p.rating) ? p.rating : 4.8;
return Math.max(0, Math.min(5, v));
}

function formatRupiah(v: number) {
return new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', maximumFractionDigits: 0 }).format(v);
}

const resolveCmsAssetUrl = (cmsBaseUrl: string, raw: string, fallback: string) => {
	const base = String(cmsBaseUrl).replace(/\/$/, '');
	const cmsOrigin = (() => {
		try {
			return new URL(base).origin;
		} catch {
			return '';
		}
	})();
	const normalizePath = (p: string) => {
		if (p.startsWith('/storage/')) return `/product-media/${p.slice('/storage/'.length)}`;
		return p;
	};
	const v = String(raw || '').trim();
	if (v === '') return fallback;
	if (v.startsWith('http://') || v.startsWith('https://')) {
		try {
			const u = new URL(v);
			u.pathname = normalizePath(u.pathname);
			const isLoopback = u.hostname === 'localhost' || u.hostname === '127.0.0.1' || u.hostname === '0.0.0.0';
			const isCms = cmsOrigin !== '' && u.origin === cmsOrigin;
			if (isLoopback || isCms) return `/cms${u.pathname}${u.search}`;
		} catch {}
		return v;
	}
	if (v.startsWith('/')) return `/cms${normalizePath(v)}`;
	return `/cms/${v}`;
};

try {
const base = String(CMS_URL).replace(/\/$/, '');
const res = await fetch(`${base}/api/products`);
if (!res.ok) throw new Error(`CMS error: ${res.status}`);
const json = await res.json().catch(() => null);
const products: Product[] = Array.isArray(json?.data) ? json.data : [];
product = products.find((p) => p.id === id) ?? null;
relatedProducts = products
.filter((p) => p.id !== id)
.slice(0, 4)
.map((p) => ({
...p,
imageUrl:
		p.image_url && String(p.image_url).trim() !== ''
			? resolveCmsAssetUrl(CMS_URL, String(p.image_url), `https://images.unsplash.com/photo-1521335629791-ce4aec67ddaf?auto=format&fit=crop&w=900&q=80`)
			: `https://images.unsplash.com/photo-1521335629791-ce4aec67ddaf?auto=format&fit=crop&w=900&q=80`,
ratingValue: ratingFrom(p),
}));
} catch {
cmsError = `Gagal mengambil data dari CMS (${CMS_URL}). Pastikan Laravel CMS sedang jalan.`;
}

if (!cmsError && !product) {
return Astro.redirect('/marketplace', 302);
}

const productImage =
	product?.image_url && String(product.image_url).trim() !== ''
		? resolveCmsAssetUrl(CMS_URL, String(product.image_url), 'https://images.unsplash.com/photo-1521335629791-ce4aec67ddaf?auto=format&fit=crop&w=900&q=80')
		: 'https://images.unsplash.com/photo-1521335629791-ce4aec67ddaf?auto=format&fit=crop&w=900&q=80';
const galleryImages = [
productImage,
`https://images.unsplash.com/photo-1531525164081-65f542250f90?auto=format&fit=crop&w=900&q=80`,
`https://images.unsplash.com/photo-1541099649105-f69ad21f3246?auto=format&fit=crop&w=900&q=80`,
`https://images.unsplash.com/photo-1512436991641-6745cdb1723db?auto=format&fit=crop&w=900&q=80`,
`https://images.unsplash.com/photo-1495121605193-b116b5b9c5d0?auto=format&fit=crop&w=900&q=80`,
];
const category = product ? pickCategory(product) : 'Marketplace';
const ratingValue = product ? ratingFrom(product) : 4.8;
const reviewCount = 240;
const soldText = '1.2k';
const isSale = product ? product.id % 3 === 0 : false;
const salePrice = product ? Math.round(product.price * 0.8) : 0;
const basePrice = product?.price ?? 0;
const badgeText = isSale ? 'Sale -20%' : 'New';
const badgeIsSale = isSale;
---

<Layout title={cmsError ? 'Marketplace' : `Marketplace - ${product?.title ?? ''}`}>
<main class="mx-auto w-full max-w-7xl px-4 pt-24 pb-16">
{cmsError ? (
<div class="rounded-3xl border border-slate-200 bg-white p-8 text-sm text-slate-600 shadow-sm">
<div class="text-base font-semibold text-slate-900">Marketplace tidak bisa dimuat</div>
<div class="mt-3">{cmsError}</div>
<div class="mt-6">
<a href="/marketplace" class="text-sm font-semibold text-slate-900 hover:text-slate-700">← Kembali ke Marketplace</a>
</div>
</div>
) : (
<section
x-data={JSON.stringify({
images: galleryImages,
mainImage: galleryImages[0],
selectedSize: 'M',
selectedColor: 'Black',
quantity: 1,
activeTab: 'Description',
})}
class="grid gap-12 lg:grid-cols-2"
>
<div>
<div class="overflow-hidden rounded-2xl border border-slate-200 bg-slate-50 shadow-sm">
<img x-bind:src="mainImage" alt={product?.title} class="h-[560px] w-full object-cover" />
</div>

<div class="mt-4 grid grid-cols-4 gap-2">
<template x-for="image in images" :key="image">
<button
type="button"
@click="mainImage = image"
class="overflow-hidden rounded-2xl border border-slate-200 bg-white transition hover:border-slate-900"
>
<img x-bind:src="image" class="h-24 w-full object-cover" />
</button>
</template>
</div>
</div>

<div class="flex flex-col rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
<nav class="text-sm text-slate-500">
<a href="/" class="hover:text-slate-700">Home</a>
<span class="mx-2">/</span>
<a href="/marketplace" class="hover:text-slate-700">Marketplace</a>
<span class="mx-2">/</span>
<span class="hover:text-slate-700">{category}</span>
<span class="mx-2">/</span>
<span class="text-slate-700">{product?.title}</span>
</nav>

<div class="mt-5 flex flex-wrap items-center gap-3">
<span class={badgeIsSale ? 'rounded-full border border-slate-900 px-3 py-1 text-xs font-semibold uppercase tracking-[0.24em] text-slate-900' : 'rounded-full bg-slate-900 px-3 py-1 text-xs font-semibold uppercase tracking-[0.24em] text-white'}>
{badgeText}
</span>
</div>

<h1 class="mt-5 text-3xl font-bold tracking-tight text-slate-900">{product?.title}</h1>

<div class="mt-4 flex flex-wrap items-center gap-3 text-sm text-slate-600">
<div class="flex items-center gap-2">
<span class="text-slate-900">⭐</span>
<span class="font-semibold text-slate-900">{ratingValue.toFixed(1)}</span>
<span>{`(${reviewCount} Reviews)`}</span>
</div>
<span class="hidden sm:inline">•</span>
<span>Sold {soldText}</span>
</div>

<div class="mt-6 flex items-end gap-4">
<div class="text-3xl font-bold tracking-tight text-slate-900">
{badgeIsSale ? formatRupiah(salePrice) : formatRupiah(basePrice)}
</div>
{badgeIsSale ? (
<div class="text-xl text-slate-400 line-through">{formatRupiah(basePrice)}</div>
) : null}
</div>

<p class="mt-6 text-sm leading-7 text-slate-600">
Rasakan detail premium dengan potongan minimalis, bahan lembut, dan siluet unisex yang mudah dipadu padankan untuk setiap acara.
</p>

<div class="my-6 h-px bg-slate-200"></div>

<div class="space-y-4">
<div>
<p class="text-sm font-medium text-slate-900">Pilih Size</p>
<div class="mt-3 flex flex-wrap gap-2">
<button
type="button"
@click="selectedSize = 'S'"
:class="selectedSize === 'S' ? 'border-slate-900 bg-slate-900 text-white' : 'border-slate-200 bg-white text-slate-900'"
class="rounded-full border px-4 py-2 text-sm font-semibold transition"
>S</button>
<button
type="button"
@click="selectedSize = 'M'"
:class="selectedSize === 'M' ? 'border-slate-900 bg-slate-900 text-white' : 'border-slate-200 bg-white text-slate-900'"
class="rounded-full border px-4 py-2 text-sm font-semibold transition"
>M</button>
<button
type="button"
@click="selectedSize = 'L'"
:class="selectedSize === 'L' ? 'border-slate-900 bg-slate-900 text-white' : 'border-slate-200 bg-white text-slate-900'"
class="rounded-full border px-4 py-2 text-sm font-semibold transition"
>L</button>
<button
type="button"
@click="selectedSize = 'XL'"
:class="selectedSize === 'XL' ? 'border-slate-900 bg-slate-900 text-white' : 'border-slate-200 bg-white text-slate-900'"
class="rounded-full border px-4 py-2 text-sm font-semibold transition"
>XL</button>
<button
type="button"
@click="selectedSize = 'XXL'"
:class="selectedSize === 'XXL' ? 'border-slate-900 bg-slate-900 text-white' : 'border-slate-200 bg-white text-slate-900'"
class="rounded-full border px-4 py-2 text-sm font-semibold transition"
>XXL</button>
</div>
</div>

<div>
<p class="text-sm font-medium text-slate-900">Pilih Color</p>
<div class="mt-3 flex items-center gap-3">
<template x-for="color in ['Black','White','Grey','Ivory']" :key="color">
<button
type="button"
@click="selectedColor = color"
class="relative flex h-8 w-8 items-center justify-center rounded-full border-2 transition"
:class="selectedColor === color ? 'border-slate-900 ring-2 ring-slate-900/20' : 'border-slate-200'"
:style="{ backgroundColor: color.toLowerCase() === 'black' ? '#0f172a' : color.toLowerCase() === 'white' ? '#ffffff' : color.toLowerCase() === 'grey' ? '#e2e8f0' : '#f8fafc' }"
aria-label="Select color"
></button>
</template>
</div>
</div>

<div>
<p class="text-sm font-medium text-slate-900">Qty</p>
<div class="mt-3 flex items-center gap-3 rounded-2xl border border-slate-200 bg-white px-3 py-2">
<button type="button" @click="quantity = Math.max(1, quantity - 1)" class="h-10 w-10 rounded-xl border border-slate-200 text-slate-900 transition hover:bg-slate-100">-</button>
<div class="min-w-[3rem] text-center text-sm font-semibold text-slate-900" x-text="quantity"></div>
<button type="button" @click="quantity += 1" class="h-10 w-10 rounded-xl border border-slate-200 text-slate-900 transition hover:bg-slate-100">+</button>
</div>
</div>
</div>

<div class="mt-6 grid gap-3">
<button type="button" class="w-full rounded-xl bg-slate-900 py-3.5 text-sm font-semibold text-white transition hover:bg-slate-800">Add to Cart</button>
<button type="button" class="w-full rounded-xl border border-slate-900 bg-white py-3.5 text-sm font-semibold text-slate-900 transition hover:bg-slate-50">Buy Now</button>
</div>

<p class="mt-4 text-xs text-slate-500">🚚 Free Shipping + 🔄 30 Days Return</p>

<div class="mt-12 rounded-3xl border border-slate-200 bg-slate-50 p-6">
<div class="flex gap-5 border-b border-slate-200 pb-4">
<button type="button" @click="activeTab = 'Description'" :class="activeTab === 'Description' ? 'border-b-2 border-slate-900 text-slate-900' : 'text-slate-600'" class="pb-3 text-sm font-semibold transition">Description</button>
<button type="button" @click="activeTab = 'Size Guide'" :class="activeTab === 'Size Guide' ? 'border-b-2 border-slate-900 text-slate-900' : 'text-slate-600'" class="pb-3 text-sm font-semibold transition">Size Guide</button>
<button type="button" @click="activeTab = 'Reviews'" :class="activeTab === 'Reviews' ? 'border-b-2 border-slate-900 text-slate-900' : 'text-slate-600'" class="pb-3 text-sm font-semibold transition">Reviews</button>
</div>

<div class="mt-6 text-sm leading-7 text-slate-600">
<div x-show="activeTab === 'Description'">
<p>Detail produk ini menonjolkan gaya monokrom yang bersih, bahan premium, dan desain yang bisa dipakai semua gender. Setiap potongan dirancang untuk terasa ringan namun berkelas.</p>
</div>
<div x-show="activeTab === 'Size Guide'" x-cloak>
<div class="grid gap-3 sm:grid-cols-2">
<div>
<p class="font-semibold text-slate-900">Size chart</p>
<p class="text-slate-600">S: 88-92 cm | M: 92-96 cm | L: 96-100 cm | XL: 100-104 cm | XXL: 104-108 cm</p>
</div>
<div>
<p class="font-semibold text-slate-900">Fit guide</p>
<p class="text-slate-600">Silhouette ini berfit nyaman. Lebih longgar untuk gaya rilaks, lebih pas untuk tampilan rapi. Pilih ukuran sesuai preferensi layering.</p>
</div>
</div>
</div>
<div x-show="activeTab === 'Reviews'" x-cloak>
<div class="space-y-4">
<div class="rounded-3xl border border-slate-200 bg-white p-4">
<div class="flex items-center justify-between text-sm text-slate-900">
<p class="font-semibold">Ava</p>
<span>4.8</span>
</div>
<p class="mt-2 text-sm text-slate-600">Potongan sangat elegan dan nyaman dipakai sepanjang hari. Kualitas bahan terasa mahal.</p>
</div>
<div class="rounded-3xl border border-slate-200 bg-white p-4">
<div class="flex items-center justify-between text-sm text-slate-900">
<p class="font-semibold">Raka</p>
<span>5.0</span>
</div>
<p class="mt-2 text-sm text-slate-600">Warna hitam putihnya sangat serbaguna. Cocok dipakai ke kantor dan acara santai.</p>
</div>
</div>
</div>
</div>
</div>
</div>
</section>

<section class="mt-16">
<h2 class="text-2xl font-bold tracking-tight text-slate-900">You May Also Like</h2>
<p class="mt-2 text-sm text-slate-600">Koleksi yang cocok untuk melengkapi gaya monokrommu.</p>

<div class="mt-6 grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
{relatedProducts.map((item) => (
<ProductCard
key={item.id}
title={item.title}
imageUrl={item.imageUrl}
category={item.category}
price={formatRupiah(item.price)}
href={`/marketplace/${item.id}-${slugify(item.title)}`}
/>
))}
</div>
</section>
)}
</main>
</Layout>
