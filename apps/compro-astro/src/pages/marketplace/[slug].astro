---
import Layout from '../../layouts/Layout.astro';

type Product = {
	id: number;
	title: string;
	categoryId?: number;
	price: number;
	rating?: number;
	image?: string;
	location?: string;
};

const CMS_URL = import.meta.env.PUBLIC_CMS_URL ?? 'http://127.0.0.1:8001';
const slug = Astro.params.slug ?? '';
const idStr = slug.split('-')[0] ?? '';
const id = Number(idStr);

if (!Number.isInteger(id) || id <= 0) {
	return Astro.redirect('/marketplace', 302);
}

let cmsError: string | null = null;
let product: Product | null = null;

try {
	const base = String(CMS_URL).replace(/\/$/, '');
	const res = await fetch(`${base}/api/products`);
	if (!res.ok) throw new Error(`CMS error: ${res.status}`);
	const json = await res.json().catch(() => null);
	const products: Product[] = Array.isArray(json?.data) ? json.data : [];
	product = products.find((p) => p.id === id) ?? null;
} catch {
	cmsError = `Gagal mengambil data dari CMS (${CMS_URL}). Pastikan Laravel CMS sedang jalan.`;
}

if (!cmsError && !product) {
	return Astro.redirect('/marketplace', 302);
}

function formatRupiah(v: number) {
	return new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', maximumFractionDigits: 0 }).format(v);
}
---

<Layout title={cmsError ? 'Marketplace' : `Marketplace - ${product?.title ?? ''}`}>
	<main class="mx-auto w-full max-w-6xl px-4 pt-24 pb-16">
		{cmsError ? (
			<div class="rounded-3xl border border-amber-200 bg-amber-50 p-6 text-sm text-amber-900 shadow-sm">
				<div class="font-semibold">Marketplace belum bisa dimuat</div>
				<div class="mt-1">{cmsError}</div>
				<div class="mt-4">
					<a href="/marketplace" class="text-sm font-semibold text-slate-700 hover:text-slate-900">← Kembali</a>
				</div>
			</div>
		) : (
			<div class="flex flex-col gap-6">
				<div class="flex items-center justify-between gap-3">
					<a href="/marketplace" class="text-sm font-semibold text-slate-700 hover:text-slate-900">← Kembali</a>
				</div>

				<div class="grid gap-6 lg:grid-cols-2 lg:items-start">
					<div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
						<div class="aspect-[4/3] w-full overflow-hidden bg-slate-100">
							<img
								src={product?.image ?? 'https://picsum.photos/seed/placeholder/600/450'}
								alt={product?.title ?? 'Produk'}
								class="h-full w-full object-cover"
							/>
						</div>
					</div>

					<div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
						<h1 class="text-2xl font-semibold tracking-tight text-slate-900">{product?.title}</h1>
						<div class="mt-2 flex flex-wrap items-center gap-2 text-sm text-slate-600">
							<span>{product?.location ?? '—'}</span>
							<span>•</span>
							<span class="font-semibold text-slate-900">{formatRupiah(product?.price ?? 0)}</span>
							{typeof product?.rating === 'number' ? (
								<>
									<span>•</span>
									<span>Rating {product.rating.toFixed(1)}</span>
								</>
							) : null}
						</div>

						<div class="mt-6 rounded-2xl bg-slate-50 p-4 text-sm text-slate-600">
							<div class="font-semibold text-slate-900">Deskripsi</div>
							<div class="mt-1 leading-7">
								Produk ini tersedia di marketplace. Untuk pemesanan/penawaran, hubungi admin lewat tombol chat di kanan bawah.
							</div>
						</div>

						<div class="mt-6 flex flex-col gap-3 sm:flex-row">
							<a
								href="/marketplace"
								class="inline-flex h-11 items-center justify-center rounded-2xl border border-slate-200 bg-white px-5 text-sm font-semibold text-slate-900 shadow-sm hover:bg-slate-50"
							>
								Lihat Produk Lain
							</a>
							<a
								href="/register"
								class="inline-flex h-11 items-center justify-center rounded-2xl bg-blue-600 px-5 text-sm font-semibold text-white shadow-sm hover:bg-blue-700"
							>
								Daftar untuk Chat
							</a>
						</div>
					</div>
				</div>
			</div>
		)}
	</main>
</Layout>
