---
import Layout from '../../layouts/Layout.astro';

type Product = {
	id: number;
	title: string;
	categoryId?: number;
	price: number;
	rating?: number;
	image?: string;
	location?: string;
};

type ProductView = Product & {
	category: string;
	sold: number;
	imageUrl: string;
	ratingValue: number;
	isMock: boolean;
	size: string;
	color: string;
};

const CMS_URL = import.meta.env.PUBLIC_CMS_URL ?? 'http://127.0.0.1:8001';
const q = (Astro.url.searchParams.get('q') ?? '').trim();

let cmsError: string | null = null;
let products: Product[] = [];

try {
	const base = String(CMS_URL).replace(/\/$/, '');
	const url = `${base}/api/products${q ? `?q=${encodeURIComponent(q)}` : ''}`;
	const res = await fetch(url);
	if (!res.ok) throw new Error(`CMS error: ${res.status}`);
	const json = await res.json().catch(() => null);
	products = Array.isArray(json?.data) ? json.data : [];
} catch {
	cmsError = `Gagal mengambil data dari CMS (${CMS_URL}). Pastikan Laravel CMS sedang jalan.`;
}

function slugify(input: string) {
	return input
		.toLowerCase()
		.trim()
		.replace(/[^a-z0-9]+/g, '-')
		.replace(/(^-|-$)/g, '');
}

function formatRupiah(v: number) {
	return new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', maximumFractionDigits: 0 }).format(v);
}

const categories = ['T-Shirts', 'Shirts', 'Hoodies', 'Pants', 'Jackets', 'Shoes', 'Accessories'];
const sizes = ['S', 'M', 'L', 'XL'];
const colors = ['Black', 'White', 'Grey', 'Ivory'];

function pickCategory(p: Product) {
	if (typeof p.categoryId === 'number' && Number.isFinite(p.categoryId)) {
		return categories[Math.abs(p.categoryId) % categories.length] ?? 'T-Shirts';
	}
	return categories[p.id % categories.length] ?? 'T-Shirts';
}

function ratingFrom(p: Product) {
	const v = typeof p.rating === 'number' && Number.isFinite(p.rating) ? p.rating : 0;
	return Math.max(0, Math.min(5, v));
}

const productsView: ProductView[] = products.map((p, idx) => {
	const category = pickCategory(p);
	const ratingValue = ratingFrom(p);
	const size = sizes[p.id % sizes.length];
	const color = colors[p.id % colors.length];
	const photoNum = (idx % 6) + 1;

	return {
		...p,
		category,
		sold: 20 + ((p.id * 37) % 800),
		ratingValue,
		imageUrl: p.image ?? `/marketplace/baju ${photoNum}.webp`,
		isMock: false,
		size,
		color,
	};
});

function makeMockProduct(index: number): ProductView {
	const id = 100000 + index;
	const titlePool = [
		'Slim Fit T-Shirt',
		'Structured Linen Shirt',
		'Signature Hoodie',
		'Tailored Wide Pants',
		'Monochrome Bomber Jacket',
		'Suede Sneaker',
		'Metallic Strap Watch',
		'Classic Leather Belt',
		'Relaxed Sweatshirt',
		'Minimalist Slip-On',
	];
	const title = titlePool[index % titlePool.length] ?? `Product ${id}`;
	const category = categories[index % categories.length] ?? 'T-Shirts';
	const price = 15000 + ((index * 2300) % 45000);
	const ratingValue = Number(((3.8 + ((index % 12) / 20)) % 5).toFixed(1));
	const size = sizes[index % sizes.length];
	const color = colors[index % colors.length];
	const photoNum = (index % 6) + 1;

	return {
		id,
		title,
		price,
		category,
		sold: 50 + ((index * 29) % 1200),
		ratingValue,
		imageUrl: `/marketplace/baju ${photoNum}.webp`,
		isMock: true,
		size,
		color,
	};
}

const desiredGridCount = 6;
const productsForGrid: ProductView[] = [...productsView];
for (let i = 0; productsForGrid.length < desiredGridCount; i += 1) {
	productsForGrid.push(makeMockProduct(i));
}

const featuredCollections = [
	{ title: 'New Arrivals', subtitle: 'Fresh luxury', image: '/images/collection-new-arrivals.jpg' },
	{ title: 'Best Seller', subtitle: 'Top picks', image: '/images/collection-best-seller.jpg' },
	{ title: "Men's Edit", subtitle: 'Sharp cuts', image: '/images/collection-mens.jpg' },
	{ title: "Women's Edit", subtitle: 'Refined essentials', image: '/images/collection-womens.jpg' },
];
---

<Layout title="Marketplace Fashion">
	<style>
		.no-scrollbar::-webkit-scrollbar { display: none; }
		.no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
		[x-cloak] { display: none !important; }
	</style>

	<main class="bg-slate-50">
		<div class="mx-auto w-full max-w-7xl px-4 pt-10 pb-16">
			<div class="space-y-10" x-data="fashionMarketplace({ initialSearch: q })" x-init="init()">
				<section class="overflow-hidden rounded-[2rem] bg-gradient-to-br from-slate-900 to-slate-700 p-8 shadow-2xl">
					<div class="grid gap-10 lg:grid-cols-[1.1fr_0.9fr]">
						<div class="flex flex-col justify-center gap-6 text-white">
							<div class="space-y-3">
								<p class="text-sm uppercase tracking-[0.28em] text-white/70">Exclusive Drop This Week</p>
								<h1 class="max-w-3xl text-5xl font-bold tracking-tight text-white">Timeless Fashion For All</h1>
								<p class="max-w-xl text-sm leading-7 text-white/80">Minimalist. Unisex. Premium cotton & sustainable materials.</p>
							</div>

							<div class="flex flex-col gap-4 sm:flex-row sm:items-center">
								<div class="overflow-hidden rounded-full border border-white/10 bg-white/10">
									<select class="h-12 rounded-full bg-transparent px-6 text-sm font-semibold text-white outline-none transition focus:border-white/20 focus:ring-2 focus:ring-white/10">
										<option selected>All Category</option>
										<option>Men</option>
										<option>Women</option>
										<option>Unisex</option>
									</select>
								</div>
								<button class="inline-flex h-12 items-center justify-center rounded-full bg-white px-6 text-sm font-semibold text-slate-900 shadow-lg shadow-slate-950/10 transition hover:scale-[1.01]">Shop Now</button>
							</div>
						</div>

						<div class="relative flex items-center justify-center overflow-hidden rounded-[1.75rem] bg-white/5 p-6 before:absolute before:-left-16 before:top-0 before:h-72 before:w-72 before:-translate-y-16 before:rounded-full before:bg-white/10">
						<img src="/images/hero-model.jpg" alt="Model fashion black and white" class="relative h-[420px] w-full max-w-[38rem] rounded-[1.75rem] object-cover shadow-2xl" />
						</div>
					</div>

					<div class="mt-10 flex flex-col gap-4 rounded-[1.75rem] border border-white/10 bg-white/5 px-5 py-4 text-sm text-white/70 sm:flex-row sm:items-center sm:justify-between">
						<div class="flex items-center gap-3">
							<div class="flex -space-x-2">
						<img src="/images/avatar-1.jpg" alt="Avatar 1" class="h-12 w-12 rounded-full border border-white/20 object-cover" />
						<img src="/images/avatar-2.jpg" alt="Avatar 2" class="h-12 w-12 rounded-full border border-white/20 object-cover" />
						<img src="/images/avatar-3.jpg" alt="Avatar 3" class="h-12 w-12 rounded-full border border-white/20 object-cover" />
							</div>
							<div class="space-y-1">
								<div class="text-sm font-semibold text-white">⭐ 4.8 (8.2K Reviews)</div>
								<div class="text-xs text-white/60">A curated audience of luxury fashion lovers.</div>
							</div>
						</div>
						<button class="inline-flex h-11 items-center justify-center rounded-full border border-white/15 bg-white/10 px-5 text-sm font-semibold text-white transition hover:bg-white/15">Sign Up Now</button>
					</div>
				</section>

				<section class="mt-10">
					<div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
						<div>
							<h2 class="text-lg font-semibold tracking-tight text-slate-900">Featured Collections</h2>
							<p class="mt-1 text-sm text-slate-600">Koleksi curated untuk penampilan monokrom premium.</p>
						</div>
					</div>

					<div class="mt-5 flex gap-3 overflow-x-auto no-scrollbar pb-1">
						{featuredCollections.map((collection) => (
							<div class="min-w-[16rem] shrink-0 rounded-full border border-slate-200 bg-slate-50 p-3 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
								<div class="flex items-center gap-3">
									<div class="flex h-16 w-16 items-center justify-center rounded-full bg-slate-900 text-sm font-semibold text-white">{collection.title.charAt(0)}</div>
									<div>
										<div class="text-sm font-semibold text-slate-900">{collection.title}</div>
										<p class="mt-1 text-xs text-slate-500">{collection.subtitle}</p>
									</div>
								</div>
							</div>
						))}
					</div>
				</section>

				<section class="mt-10 rounded-[2rem] border border-slate-200 bg-white/90 p-5 shadow-sm backdrop-blur-md">
					<div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
						<div class="flex flex-1 flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
							<div class="relative flex-1">
								<input
									x-model="search"
									@input.debounce.150ms="apply()"
									placeholder="Cari produk premium..."
									class="h-12 w-full rounded-xl border-0 bg-slate-100 px-4 text-sm text-slate-900 shadow-sm outline-none placeholder:text-slate-500 focus:ring-2 focus:ring-slate-900/10"
								/>
							</div>
							<div class="flex flex-wrap items-center gap-2">
								<button
									type="button"
									@click="togglePill('new')"
									class="inline-flex h-11 items-center justify-center rounded-full px-4 text-sm font-semibold transition"
									:class="activeFilters.new ? 'bg-slate-900 text-white' : 'bg-slate-100 text-slate-900 hover:bg-slate-200'"
								>
									New
								</button>
								<button
									type="button"
									@click="togglePill('sale')"
									class="inline-flex h-11 items-center justify-center rounded-full px-4 text-sm font-semibold transition"
									:class="activeFilters.sale ? 'bg-slate-900 text-white' : 'bg-slate-100 text-slate-900 hover:bg-slate-200'"
								>
									Sale
								</button>
								<button
									type="button"
									@click="togglePill('rating')"
									class="inline-flex h-11 items-center justify-center rounded-full px-4 text-sm font-semibold transition"
									:class="activeFilters.rating ? 'bg-slate-900 text-white' : 'bg-slate-100 text-slate-900 hover:bg-slate-200'"
								>
									⭐ 4.5+
								</button>
							</div>
						</div>

						<div class="relative">
							<button
								type="button"
								@click="open = !open"
								class="inline-flex h-11 items-center justify-center gap-2 rounded-full bg-slate-900 px-4 text-sm font-semibold text-white shadow-sm transition hover:bg-slate-800"
							>
								Filter
								<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
									<path d="M6 9l6 6 6-6" />
								</svg>
							</button>

							<div x-show="open" x-cloak @click.outside="open = false" class="absolute right-0 z-30 mt-3 w-72 rounded-3xl border border-slate-200 bg-white p-4 shadow-lg">
								<div class="grid gap-4">
									<div>
										<label class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Size</label>
										<select x-model="size" @change="apply()" class="mt-2 h-11 w-full rounded-2xl border-0 bg-slate-100 px-3 text-sm text-slate-900 shadow-sm outline-none focus:ring-2 focus:ring-slate-900/10">
											<option value="">All sizes</option>
											<option value="S">S</option>
											<option value="M">M</option>
											<option value="L">L</option>
											<option value="XL">XL</option>
										</select>
									</div>
									<div>
										<label class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Color</label>
										<select x-model="color" @change="apply()" class="mt-2 h-11 w-full rounded-2xl border-0 bg-slate-100 px-3 text-sm text-slate-900 shadow-sm outline-none focus:ring-2 focus:ring-slate-900/10">
											<option value="">All colors</option>
											<option value="Black">Black</option>
											<option value="White">White</option>
											<option value="Grey">Grey</option>
											<option value="Ivory">Ivory</option>
										</select>
									</div>
									<div>
										<label class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500">Price</label>
										<select x-model="price" @change="apply()" class="mt-2 h-11 w-full rounded-2xl border-0 bg-slate-100 px-3 text-sm text-slate-900 shadow-sm outline-none focus:ring-2 focus:ring-slate-900/10">
											<option value="">All prices</option>
											<option value="0-15000">Rp 0 - 15rb</option>
											<option value="15000-25000">Rp 15rb - 25rb</option>
											<option value="25000-999999">Rp 25rb+</option>
										</select>
									</div>
								</div>
							</div>
						</div>
					</div>
				</section>

				{cmsError ? (
					<div class="rounded-2xl border border-slate-200 bg-white p-6 text-sm text-slate-600 shadow-sm">
						{cmsError}
					</div>
				) : (
					<>
						<section class="mt-8">
							<div class="flex items-center justify-between gap-4">
								<div>
									<h2 class="text-lg font-semibold tracking-tight text-slate-900">Curated Product Grid</h2>
									<p class="mt-1 text-sm text-slate-600">Luxury essentials dalam palet monokrom.</p>
								</div>
								<div class="text-sm text-slate-500"><span id="products-count">{productsForGrid.length}</span> items</div>
							</div>

							<div id="product-grid" class="mt-6 grid grid-cols-3 grid-rows-2 gap-4">
								{productsForGrid.map((p) => {
									const isSale = p.id % 3 === 0;
									return (
										<article
									data-product-card
									data-title={p.title.toLowerCase()}
									data-category={p.category}
									data-new={String(p.id % 2 === 0)}
									data-sale={String(isSale)}
									data-price={String(p.price)}
									data-rating={String(p.ratingValue)}
									data-size={p.size}
									data-color={p.color}
									class="overflow-hidden rounded-2xl border border-slate-200/80 bg-white transition duration-200 hover:-translate-y-0.5 hover:shadow-lg"
								>
									<div class="relative h-60 overflow-hidden bg-slate-100">
										<img src={p.imageUrl} alt={p.title} loading="lazy" class="h-full w-full object-cover transition duration-300 hover:scale-[1.03]" />
										<span class="absolute left-3 top-3 rounded-full bg-slate-900 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.24em] text-white">New</span>
										{isSale ? (
											<span class="absolute right-3 top-3 rounded-full border border-slate-200 bg-white px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.24em] text-slate-900">Sale</span>
										) : null}
									</div>
									<div class="space-y-3 p-4">
										<div class="text-sm font-semibold text-slate-900">{p.title}</div>
										<div class="flex flex-col gap-1 text-xs uppercase tracking-[0.28em] text-slate-500 sm:flex-row sm:items-center sm:justify-between">
											<span>{p.category}</span>
											<span>{p.size} · {p.color}</span>
										</div>
										<div class="flex items-center justify-between gap-3">
											<div class="text-base font-bold text-slate-900">{formatRupiah(p.price)}</div>
											<button type="button" class="inline-flex h-11 w-11 items-center justify-center rounded-full bg-slate-900 text-white shadow-sm transition hover:bg-slate-800" data-cart-add data-cart-id={p.id} aria-label="Add to cart">
												<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
													<path d="M12 5v14" />
													<path d="M5 12h14" />
												</svg>
											</button>
										</div>
									</div>
								</article>
							);
						})}
					</div>
				</section>

				<div id="products-empty" class="hidden rounded-2xl border border-slate-200 bg-white p-6 text-sm text-slate-600 shadow-sm">
					Tidak ada produk yang cocok dengan filter.
				</div>
							</>
						)}
		<script is:inline>
			window.fashionMarketplace = function fashionMarketplace({ initialSearch }) {
				return {
					open: false,
					search: String(initialSearch || ''),
					activeCategory: 'All',
					activeFilters: { new: false, sale: false, rating: false },
					size: '',
					color: '',
					price: '',
					init() {
						this.apply();
					},
					togglePill(key) {
						this.activeFilters[key] = !this.activeFilters[key];
						this.apply();
					},
					setCategory(category) {
						this.activeCategory = category;
						this.apply();
					},
					apply() {
						const search = String(this.search || '').trim().toLowerCase();
						const category = String(this.activeCategory || '').trim();
						const showNew = !!this.activeFilters.new;
						const showSale = !!this.activeFilters.sale;
						const showRating = !!this.activeFilters.rating;
						const size = String(this.size || '').trim();
						const color = String(this.color || '').trim();
						const price = String(this.price || '').trim();

						let minPrice = null;
						let maxPrice = null;
						if (price.includes('-')) {
							const [a, b] = price.split('-');
							minPrice = Number(a) || null;
							maxPrice = Number(b) || null;
						}

						const cards = Array.from(document.querySelectorAll('[data-product-card]'));
						let shown = 0;

						for (const card of cards) {
							const title = String(card.getAttribute('data-title') || '');
							const cat = String(card.getAttribute('data-category') || '');
							const isNew = String(card.getAttribute('data-new') || '') === 'true';
							const isSale = String(card.getAttribute('data-sale') || '') === 'true';
							const cardRating = Number(card.getAttribute('data-rating') || '0');
							const cardSize = String(card.getAttribute('data-size') || '');
							const cardColor = String(card.getAttribute('data-color') || '');
							const cardPrice = Number(card.getAttribute('data-price') || '0');

							let visible = true;
							if (search && !title.includes(search)) visible = false;
							if (category && category !== 'All' && cat !== category) visible = false;
							if (showNew && !isNew) visible = false;
							if (showSale && !isSale) visible = false;
							if (showRating && cardRating < 4.5) visible = false;
							if (size && cardSize !== size) visible = false;
							if (color && cardColor !== color) visible = false;
							if (minPrice !== null && cardPrice < minPrice) visible = false;
							if (maxPrice !== null && cardPrice > maxPrice) visible = false;

							if (visible) {
								card.classList.remove('hidden');
								shown += 1;
							} else {
								card.classList.add('hidden');
							}
						}

						const countEl = document.getElementById('products-count');
						if (countEl) countEl.textContent = String(shown);

						const emptyEl = document.getElementById('products-empty');
						if (emptyEl) emptyEl.classList.toggle('hidden', shown !== 0);
					}
				};
			};
		</script>

		<script is:inline data-astro-rerun>
			(function () {
				const KEY = 'cart_items';
				const readItems = () => {
					try {
						const raw = window.localStorage.getItem(KEY);
						if (!raw) return [];
						const arr = JSON.parse(raw);
						return Array.isArray(arr) ? arr : [];
					} catch {
						return [];
					}
				};
				const writeItems = (items) => {
					try {
						window.localStorage.setItem(KEY, JSON.stringify(items));
					} catch {}
				};
				const countItems = (items) => {
					let sum = 0;
					for (const it of items) {
						const q = Number(it?.qty ?? 0);
						if (Number.isFinite(q) && q > 0) sum += Math.trunc(q);
					}
					return sum;
				};

				document.addEventListener('click', (e) => {
					const t = e.target instanceof Element ? e.target.closest('[data-cart-add]') : null;
					if (!t) return;
					e.preventDefault();
					e.stopPropagation();
					const id = Number(t.getAttribute('data-cart-id') || '0');
					if (!Number.isInteger(id) || id <= 0) return;

					const items = readItems();
					const idx = items.findIndex((x) => Number(x?.id) === id);
					if (idx >= 0) {
						const prev = Number(items[idx]?.qty ?? 0);
						items[idx] = { id, qty: Math.max(1, (Number.isFinite(prev) ? Math.trunc(prev) : 0) + 1) };
					} else {
						items.push({ id, qty: 1 });
					}
					writeItems(items);
					const count = countItems(items);
					window.dispatchEvent(new CustomEvent('cart:updated', { detail: { count } }));
				});
			})();
		</script>

		<script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
	</main>
</Layout>
