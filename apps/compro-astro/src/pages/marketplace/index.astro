		<script is:inline data-astro-rerun define:vars={{ CMS_URL }}>
			window.quickAddModal = (() => {
				let instance = null;
				const KEY = 'cart_items';
				const resolveCmsBase = () => {
					const raw = String(CMS_URL || '').trim().replace(/\/$/, '');
					if (!raw) return '';
					try {
						const u = new URL(raw);
						const isLoopback = u.hostname === 'localhost' || u.hostname === '127.0.0.1';
						if (isLoopback) u.hostname = window.location.hostname;
						return u.origin;
					} catch {
						return raw;
					}
				};
				const CMS_BASE = resolveCmsBase();

				const getAuth = () => {
					const token = String(window.localStorage.getItem('token_pelanggan') || '').trim();
					const pelangganId = String(window.localStorage.getItem('id_pelanggan') || '').trim();
					const id = Number(pelangganId || '0');
					return { token, pelangganId: pelangganId || '', id: Number.isFinite(id) && id > 0 ? String(Math.trunc(id)) : '' };
				};

				const normalizeForServer = (items) => {
					const out = [];
					for (const it of Array.isArray(items) ? items : []) {
						const productId = Number(it?.product_id ?? 0);
						if (!Number.isFinite(productId) || productId <= 0) continue;
						const rawVariantId = it?.variant_id;
						const variantId = rawVariantId === null || rawVariantId === undefined ? null : Number(rawVariantId);
						const qty = Math.max(1, Math.trunc(Number(it?.qty ?? 1)));
						const price = Math.max(0, Math.trunc(Number(it?.price ?? 0)));
						out.push({
							product_id: Math.trunc(productId),
							variant_id: Number.isFinite(variantId) && variantId > 0 ? Math.trunc(variantId) : null,
							qty,
							title: String(it?.title ?? '').trim(),
							image: String(it?.image ?? '').trim(),
							size: String(it?.size ?? '').trim(),
							price,
						});
					}
					return out;
				};

				const syncToServer = (items) => {
					if (!CMS_BASE) return;
					const auth = getAuth();
					if (!auth.id && !auth.token) return;
					fetch(`${CMS_BASE}/api/cart/sync`, {
						method: 'POST',
						headers: {
							'Content-Type': 'application/json',
							...(auth.token ? { Authorization: `Bearer ${auth.token}` } : {}),
							...(auth.id ? { 'X-Pelanggan-Id': auth.id } : {}),
						},
						body: JSON.stringify({ items: normalizeForServer(items) }),
					}).catch(() => {});
				};

				const readItems = () => {
					try {
						const raw = window.localStorage.getItem(KEY);
						if (!raw) return [];
						const arr = JSON.parse(raw);
						return Array.isArray(arr) ? arr : [];
					} catch {
						return [];
					}
				};

				const writeItems = (items) => {
					try {
						window.localStorage.setItem(KEY, JSON.stringify(items));
					} catch {}
				};

				const countItems = (items) => {
					let sum = 0;
					for (const it of items) {
						const q = Number(it?.qty ?? 0);
						if (Number.isFinite(q) && q > 0) sum += Math.trunc(q);
					}
					return sum;
				};

				const formatPrice = (n) => {
					const v = Number(n ?? 0);
					const safe = Number.isFinite(v) ? Math.max(0, Math.trunc(v)) : 0;
					return `Rp ${safe.toString().replace(/\B(?=(\d{3})+(?!\d))/g, '.')}`;
				};

				const showToast = (message) => {
					const root = document.getElementById('toast-root');
					if (!root) return;
					const TOAST_ID = 'cart-toast';
					const existing = document.getElementById(TOAST_ID);
					if (existing) existing.remove();

					const el = document.createElement('div');
					el.id = TOAST_ID;
					el.className = 'toast-enter rounded-2xl border border-zinc-200 bg-white/90 px-4 py-3 text-sm text-zinc-900 shadow-lg backdrop-blur-md';
					el.setAttribute('role', 'status');
					el.setAttribute('aria-live', 'polite');
					el.textContent = message;
					root.appendChild(el);

					requestAnimationFrame(() => {
						el.classList.add('toast-enter-active');
						el.classList.remove('toast-enter');
					});

					window.setTimeout(() => {
						el.classList.add('toast-leave-active');
						window.setTimeout(() => el.remove(), 200);
					}, 1600);
				};

				const create = () => ({
					open: false,
					product: null,
					variants: [],
					selectedSize: null,
					qty: 1,
					addSimple(productId, qty, meta = null) {
						if (!Number.isInteger(productId) || productId <= 0) return;
						const safeQty = Math.max(1, Math.trunc(Number(qty || 1)));
						const metaObj = meta && typeof meta === 'object' ? meta : {};
						const metaTitle = String(metaObj?.title ?? '').trim();
						const metaImage = String(metaObj?.image ?? '').trim();
						const metaPriceRaw = Number(metaObj?.price ?? metaObj?.priceValue ?? NaN);
						const metaPrice = Number.isFinite(metaPriceRaw) ? Math.max(0, Math.trunc(metaPriceRaw)) : null;

						const items = readItems();
						const idx = items.findIndex((x) => Number(x?.product_id ?? 0) === productId && (x?.variant_id === null || x?.variant_id === undefined));
						if (idx >= 0) {
							const prev = Number(items[idx]?.qty ?? 0);
							items[idx] = {
								...items[idx],
								product_id: productId,
								variant_id: null,
								qty: Math.max(1, (Number.isFinite(prev) ? Math.trunc(prev) : 0) + safeQty),
								title: metaTitle || items[idx]?.title,
								image: metaImage || items[idx]?.image,
								price: metaPrice === null ? items[idx]?.price : metaPrice,
							};
						} else {
							items.push({ product_id: productId, variant_id: null, qty: safeQty, title: metaTitle, image: metaImage, price: metaPrice ?? 0 });
						}
						writeItems(items);
						const count = countItems(items);
						window.dispatchEvent(new CustomEvent('cart:updated', { detail: { count } }));
						showToast('Berhasil tambah ke keranjang');
						syncToServer(items);
					},
					getSelectedStock() {
						const v = this.variants.find((x) => Number(x?.id) === Number(this.selectedSize));
						return v ? Number(v.stock || 0) : 0;
					},
					show(productEl) {
						if (!productEl) return;
						const id = Number(productEl.dataset.productId || '0');
						const title = String(productEl.dataset.title || '').trim();
						const price = String(productEl.dataset.price || '').trim();
						const priceValueRaw = Number(productEl.dataset.priceValue || '0');
						const priceValue = Number.isFinite(priceValueRaw) ? Math.max(0, Math.trunc(priceValueRaw)) : 0;
						const image = String(productEl.dataset.image || '').trim();

						let variants = [];
						try {
							const raw = String(productEl.dataset.variants || '[]');
							const arr = JSON.parse(raw);
							variants = Array.isArray(arr) ? arr : [];
						} catch {
							variants = [];
						}

						this.product = { id, title, price, priceValue, image };
						this.variants = variants
							.map((x) => ({
								id: Number(x?.id ?? 0),
								size: String(x?.size ?? '').trim(),
								stock: Number(x?.stock ?? 0),
								price: x?.price === null || x?.price === undefined ? null : Number(x.price),
							}))
							.filter((x) => Number.isFinite(x.id) && x.id > 0 && x.size);

						if (!this.variants.length) {
							this.addSimple(id, 1, { title, image, price: priceValue });
							return;
						}

						this.qty = 1;
						this.selectedSize = (this.variants.find((v) => Number(v.stock || 0) > 0)?.id ?? null);
						this.open = true;
					},
					addToCart() {
						const productId = Number(this.product?.id ?? 0);
						const variantId = Number(this.selectedSize ?? 0);
						const variant = this.variants.find((x) => Number(x?.id) === variantId) || null;
						if (!Number.isInteger(productId) || productId <= 0) return;
						if (!Number.isInteger(variantId) || variantId <= 0) return;
						if (!variant) return;
						if (Number(variant.stock || 0) <= 0) return;

						const maxQty = Math.max(1, Math.trunc(Number(variant.stock || 0)));
						const qty = Math.max(1, Math.min(maxQty, Math.trunc(Number(this.qty || 1))));
						const basePriceRaw = Number(this.product?.priceValue ?? 0);
						const basePrice = Number.isFinite(basePriceRaw) ? Math.max(0, Math.trunc(basePriceRaw)) : 0;
						const variantPriceRaw = variant?.price === null || variant?.price === undefined ? NaN : Number(variant.price);
						const chosenPrice = Number.isFinite(variantPriceRaw) ? Math.max(0, Math.trunc(variantPriceRaw)) : basePrice;
						const title = String(this.product?.title ?? '').trim();
						const image = String(this.product?.image ?? '').trim();
						const sizeLabel = String(variant.size || '').trim();

						const items = readItems();
						const idx = items.findIndex((x) => Number(x?.variant_id ?? 0) === variantId);
						if (idx >= 0) {
							const prev = Number(items[idx]?.qty ?? 0);
							const next = Math.max(1, Math.min(maxQty, (Number.isFinite(prev) ? Math.trunc(prev) : 0) + qty));
							items[idx] = {
								...items[idx],
								product_id: productId,
								variant_id: variantId,
								qty: next,
								title: title || items[idx]?.title,
								image: image || items[idx]?.image,
								price: chosenPrice,
								size: sizeLabel || items[idx]?.size,
							};
						} else {
							items.push({ product_id: productId, variant_id: variantId, qty, title, image, price: chosenPrice, size: sizeLabel });
						}

						writeItems(items);
						const count = countItems(items);
						window.dispatchEvent(new CustomEvent('cart:updated', { detail: { count } }));

						showToast(sizeLabel ? `Berhasil tambah ukuran ${sizeLabel}` : 'Berhasil tambah ke keranjang');
						syncToServer(items);
						this.open = false;
					},
				});

				return () => {
					if (!instance) instance = create();
					return instance;
				};
			})();
		</script>

