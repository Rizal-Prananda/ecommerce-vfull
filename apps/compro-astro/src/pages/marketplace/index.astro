---
import Layout from '../../layouts/Layout.astro';

type Product = {
	id: number;
	title: string;
	categoryId?: number;
	price: number;
	rating?: number;
	image?: string;
	location?: string;
};

const CMS_URL = import.meta.env.PUBLIC_CMS_URL ?? 'http://127.0.0.1:8001';
const q = (Astro.url.searchParams.get('q') ?? '').trim();

let cmsError: string | null = null;
let products: Product[] = [];

try {
	const base = String(CMS_URL).replace(/\/$/, '');
	const url = `${base}/api/products${q ? `?q=${encodeURIComponent(q)}` : ''}`;
	const res = await fetch(url);
	if (!res.ok) throw new Error(`CMS error: ${res.status}`);
	const json = await res.json().catch(() => null);
	products = Array.isArray(json?.data) ? json.data : [];
} catch {
	cmsError = `Gagal mengambil data dari CMS (${CMS_URL}). Pastikan Laravel CMS sedang jalan.`;
}

function slugify(input: string) {
	return input
		.toLowerCase()
		.trim()
		.replace(/[^a-z0-9]+/g, '-')
		.replace(/(^-|-$)/g, '');
}

function formatRupiah(v: number) {
	return new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', maximumFractionDigits: 0 }).format(v);
}
---

<Layout title="Marketplace">
	<main class="mx-auto w-full max-w-6xl px-4 pt-24 pb-16">
		<div class="flex flex-col gap-6">
			<div class="flex flex-col gap-2">
				<h1 class="text-3xl font-semibold tracking-tight text-slate-900">Marketplace</h1>
				<p class="text-sm text-slate-600">Cari produk dan layanan terbaik.</p>
			</div>

			<form method="get" class="flex flex-col gap-3 sm:flex-row sm:items-center">
				<input
					name="q"
					value={q}
					placeholder="Cari produk..."
					class="h-11 w-full rounded-2xl border border-slate-200 bg-white px-4 text-sm text-slate-900 shadow-sm outline-none ring-0 placeholder:text-slate-400 focus:border-slate-300 focus:ring-2 focus:ring-slate-200/70 sm:flex-1"
				/>
				<button
					type="submit"
					class="inline-flex h-11 items-center justify-center rounded-2xl bg-blue-600 px-5 text-sm font-semibold text-white shadow-sm hover:bg-blue-700"
				>
					Cari
				</button>
			</form>

			{products.length ? (
				<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
					{products.map((p) => (
						<a
							href={`/marketplace/${p.id}-${slugify(p.title)}`}
							class="group overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm transition hover:-translate-y-0.5 hover:shadow-md"
						>
							<div class="aspect-[4/3] w-full overflow-hidden bg-slate-100">
								<img
									src={p.image ?? 'https://picsum.photos/seed/placeholder/600/450'}
									alt={p.title}
									class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.03]"
									loading="lazy"
								/>
							</div>
							<div class="p-4">
								<div class="flex items-start justify-between gap-3">
									<div class="min-w-0">
										<div class="truncate text-sm font-semibold text-slate-900">{p.title}</div>
										<div class="mt-1 text-xs text-slate-600">{p.location ?? '—'}</div>
									</div>
									<div class="shrink-0 text-right">
										<div class="text-sm font-semibold text-slate-900">{formatRupiah(p.price)}</div>
										{typeof p.rating === 'number' ? (
											<div class="mt-1 text-xs text-slate-600">Rating {p.rating.toFixed(1)}</div>
										) : null}
									</div>
								</div>
								<div class="mt-4 inline-flex items-center gap-2 text-xs font-semibold text-blue-700">
									Lihat detail
									<span class="transition-transform group-hover:translate-x-0.5">→</span>
								</div>
							</div>
						</a>
					))}
				</div>
			) : cmsError ? (
				<div class="rounded-3xl border border-amber-200 bg-amber-50 p-6 text-sm text-amber-900 shadow-sm">
					{cmsError}
				</div>
			) : (
				<div class="rounded-3xl border border-slate-200 bg-white p-6 text-sm text-slate-600 shadow-sm">
					{q ? `Produk "${q}" tidak ditemukan.` : 'Belum ada produk.'}
				</div>
			)}
		</div>
	</main>
</Layout>
