---
import Layout from '../../layouts/Layout.astro';

type Product = {
	id: number;
	title: string;
	slug: string;
	category: string;
	price_formatted: string;
	rating: number;
	image_url: string | null;
	stock: number;
	is_new?: boolean;
	is_sale?: boolean;
	is_sold?: boolean;
};

type ProductView = Product & {
	sold: number;
	imageUrl: string;
	ratingValue: number;
	isMock: boolean;
	size: string;
	color: string;
	priceValue: number;
};

const CMS_URL = import.meta.env.PUBLIC_CMS_URL ?? 'http://127.0.0.1:8001';
const q = (Astro.url.searchParams.get('q') ?? '').trim();

let cmsError: string | null = null;
let products: Product[] = [];

try {
	const base = String(CMS_URL).replace(/\/$/, '');
	const url = `${base}/api/products${q ? `?q=${encodeURIComponent(q)}` : ''}`;
	const res = await fetch(url);
	if (!res.ok) throw new Error(`CMS error: ${res.status}`);
	const json = await res.json().catch(() => null);
	products = Array.isArray(json?.data) ? json.data : [];
} catch {
	cmsError = `Gagal mengambil data dari CMS (${CMS_URL}). Pastikan Laravel CMS sedang jalan.`;
}

function rupiahToNumber(input: string) {
	const digits = String(input || '').replace(/[^\d]/g, '');
	const n = Number(digits || '0');
	return Number.isFinite(n) ? Math.max(0, Math.trunc(n)) : 0;
}

const categoriesFromApi = Array.from(
	new Set(products.map((p) => String(p?.category || '').trim()).filter(Boolean)),
).sort((a, b) => a.localeCompare(b));
const categories = categoriesFromApi.length ? categoriesFromApi : ['General'];
const sizes = ['S', 'M', 'L', 'XL'];
const colors = ['Black', 'White', 'Grey', 'Ivory'];

function ratingFrom(p: Product) {
	const v = typeof p.rating === 'number' && Number.isFinite(p.rating) ? p.rating : 0;
	return Math.max(0, Math.min(5, v));
}

const productsView: ProductView[] = products.map((p, idx) => {
	const ratingValue = ratingFrom(p);
	const size = sizes[p.id % sizes.length];
	const color = colors[p.id % colors.length];
	const photoNum = (idx % 6) + 1;
	const imageUrl = (p.image_url && String(p.image_url).trim() !== '') ? String(p.image_url) : `/marketplace/baju ${photoNum}.webp`;

	return {
		...p,
		sold: 20 + ((p.id * 37) % 800),
		ratingValue,
		imageUrl,
		isMock: false,
		size,
		color,
		priceValue: rupiahToNumber(p.price_formatted),
	};
});

const productsForGrid: ProductView[] = productsView;

const featuredCollections = [
	{ title: 'New Arrivals', subtitle: 'Fresh luxury', image: '/images/collection-new-arrivals.jpg' },
	{ title: 'Best Seller', subtitle: 'Top picks', image: '/images/collection-best-seller.jpg' },
	{ title: "Men's Edit", subtitle: 'Sharp cuts', image: '/images/collection-mens.jpg' },
	{ title: "Women's Edit", subtitle: 'Refined essentials', image: '/images/collection-womens.jpg' },
];
---

<Layout title="Marketplace">
	<style>
		.no-scrollbar::-webkit-scrollbar { display: none; }
		.no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
		[x-cloak] { display: none !important; }
		:global(.toast-enter) { opacity: 0; transform: translateY(8px); }
		:global(.toast-enter-active) { opacity: 1; transform: translateY(0); transition: opacity 180ms ease, transform 180ms ease; }
		:global(.toast-leave-active) { opacity: 0; transform: translateY(8px); transition: opacity 180ms ease, transform 180ms ease; }
		:global(.ripple) {
			position: absolute;
			border-radius: 9999px;
			transform: scale(0);
			animation: marketplace-ripple 520ms ease-out;
			background: rgba(255, 255, 255, 0.35);
			pointer-events: none;
		}
		@keyframes marketplace-ripple {
			to { transform: scale(4); opacity: 0; }
		}
	</style>

	<main class="bg-zinc-50 text-zinc-900 [font-family:Inter,ui-sans-serif,system-ui]">
		<div class="mx-auto w-full max-w-7xl px-4 pt-10 pb-16">
			<div class="space-y-10" x-data="fashionMarketplace({ initialSearch: q })" x-init="init()">
				<section class="overflow-hidden rounded-[2rem] bg-gradient-to-br from-slate-900 to-slate-700 p-8 shadow-2xl">
					<div class="grid gap-10 lg:grid-cols-[1.1fr_0.9fr]">
						<div class="flex flex-col justify-center gap-6 text-white">
							<div class="space-y-3">
								<p class="text-sm uppercase tracking-[0.28em] text-white/70">Exclusive Drop This Week</p>
								<h1 class="max-w-3xl text-5xl font-bold tracking-tight text-white">Timeless Fashion For All</h1>
								<p class="max-w-xl text-sm leading-7 text-white/80">Minimalist. Unisex. Premium cotton & sustainable materials.</p>
							</div>

							<div class="flex flex-col gap-4 sm:flex-row sm:items-center">
								<div class="overflow-hidden rounded-full border border-white/10 bg-white/10">
									<select class="h-12 rounded-full bg-transparent px-6 text-sm font-semibold text-white outline-none transition focus:border-white/20 focus:ring-2 focus:ring-white/10">
										<option selected>All Category</option>
										<option>Men</option>
										<option>Women</option>
										<option>Unisex</option>
									</select>
								</div>
								<button class="inline-flex h-12 items-center justify-center rounded-full bg-white px-6 text-sm font-semibold text-slate-900 shadow-lg shadow-slate-950/10 transition hover:scale-[1.01]">Shop Now</button>
							</div>
						</div>

						<div class="relative flex items-center justify-center overflow-hidden rounded-[1.75rem] bg-white/5 p-6 before:absolute before:-left-16 before:top-0 before:h-72 before:w-72 before:-translate-y-16 before:rounded-full before:bg-white/10">
						<img src="/marketplace/baju 1.webp" alt="Avenue Collective lookbook" class="relative h-[420px] w-full max-w-[38rem] rounded-[1.75rem] object-cover shadow-2xl" />
						</div>
					</div>

					<div class="mt-10 flex flex-col gap-4 rounded-[1.75rem] border border-white/10 bg-white/5 px-5 py-4 text-sm text-white/70 sm:flex-row sm:items-center sm:justify-between">
						<div class="flex items-center gap-3">
							<div class="flex -space-x-2">
						<img src="/marketplace/baju 2.webp" alt="Customer 1" class="h-12 w-12 rounded-full border border-white/20 object-cover" />
						<img src="/marketplace/baju 3.webp" alt="Customer 2" class="h-12 w-12 rounded-full border border-white/20 object-cover" />
						<img src="/marketplace/baju 4.webp" alt="Customer 3" class="h-12 w-12 rounded-full border border-white/20 object-cover" />
							</div>
							<div class="space-y-1">
								<div class="text-sm font-semibold text-white">⭐ 4.8 (8.2K Reviews)</div>
								<div class="text-xs text-white/60">A curated audience of luxury fashion lovers.</div>
							</div>
						</div>
						<button class="inline-flex h-11 items-center justify-center rounded-full border border-white/15 bg-white/10 px-5 text-sm font-semibold text-white transition hover:bg-white/15">Sign Up Now</button>
					</div>
				</section>

				<section class="mt-10">
					<div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
						<div>
							<h2 class="text-lg font-semibold tracking-tight text-slate-900">Featured Collections</h2>
							<p class="mt-1 text-sm text-slate-600">Koleksi curated untuk penampilan monokrom premium.</p>
						</div>
					</div>

					<div class="mt-5 flex gap-3 overflow-x-auto no-scrollbar pb-1">
						{featuredCollections.map((collection) => (
							<div class="min-w-[16rem] shrink-0 rounded-full border border-slate-200 bg-slate-50 p-3 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
								<div class="flex items-center gap-3">
									<div class="flex h-16 w-16 items-center justify-center rounded-full bg-slate-900 text-sm font-semibold text-white">{collection.title.charAt(0)}</div>
									<div>
										<div class="text-sm font-semibold text-slate-900">{collection.title}</div>
										<p class="mt-1 text-xs text-slate-500">{collection.subtitle}</p>
									</div>
								</div>
							</div>
						))}
					</div>
				</section>

				<section class="mt-10 grid gap-8 lg:grid-cols-[280px_1fr]">
					<aside class="h-fit rounded-2xl border border-zinc-200 bg-white/80 p-6 shadow-sm backdrop-blur-md lg:sticky lg:top-24">
						<div class="flex items-center justify-between gap-3">
							<div class="text-sm font-semibold text-zinc-900">Filters</div>
							<button type="button" class="text-xs font-semibold text-zinc-500 hover:text-zinc-900" @click="reset()">Reset</button>
						</div>

						<div class="mt-4 space-y-5">
							<div>
								<label class="text-xs font-semibold uppercase tracking-[0.22em] text-zinc-400">Search</label>
								<input
									x-model="search"
									@input.debounce.150ms="apply()"
									placeholder="Search Avenue Collective..."
									class="mt-2 h-11 w-full rounded-xl border border-zinc-100 bg-zinc-50 px-4 text-sm text-zinc-900 shadow-sm outline-none placeholder:text-zinc-400 focus:bg-white focus:ring-2 focus:ring-zinc-900/10"
								/>
							</div>

							<div>
								<div class="text-xs font-semibold uppercase tracking-[0.22em] text-zinc-400">Category</div>
								<div class="mt-3 space-y-2">
									{categories.map((c) => (
										<label class="flex items-center justify-between gap-3 rounded-xl border border-zinc-100 bg-white px-3 py-2 text-sm text-zinc-700">
											<span class="flex items-center gap-3">
												<input
													type="checkbox"
													class="h-4 w-4 rounded border-zinc-300 text-black focus:ring-black/20"
													x-model="selectedCategories"
													value={c}
													@change="apply()"
												/>
												<span class="font-medium">{c}</span>
											</span>
										</label>
									))}
								</div>
							</div>

							<div>
								<div class="text-xs font-semibold uppercase tracking-[0.22em] text-zinc-400">Quick</div>
								<div class="mt-3 grid gap-2">
									<label class="flex items-center justify-between gap-3 rounded-xl border border-zinc-100 bg-white px-3 py-2 text-sm text-zinc-700">
										<span class="flex items-center gap-3">
											<input type="checkbox" class="h-4 w-4 rounded border-zinc-300 text-black focus:ring-black/20" x-model="activeFilters.new" @change="apply()" />
											<span class="font-medium">New</span>
										</span>
									</label>
									<label class="flex items-center justify-between gap-3 rounded-xl border border-zinc-100 bg-white px-3 py-2 text-sm text-zinc-700">
										<span class="flex items-center gap-3">
											<input type="checkbox" class="h-4 w-4 rounded border-zinc-300 text-black focus:ring-black/20" x-model="activeFilters.sale" @change="apply()" />
											<span class="font-medium">Sale</span>
										</span>
									</label>
									<label class="flex items-center justify-between gap-3 rounded-xl border border-zinc-100 bg-white px-3 py-2 text-sm text-zinc-700">
										<span class="flex items-center gap-3">
											<input type="checkbox" class="h-4 w-4 rounded border-zinc-300 text-black focus:ring-black/20" x-model="activeFilters.rating" @change="apply()" />
											<span class="font-medium">⭐ 4.5+</span>
										</span>
									</label>
								</div>
							</div>

							<div class="grid gap-4">
								<div>
									<label class="text-xs font-semibold uppercase tracking-[0.22em] text-zinc-400">Size</label>
									<select x-model="size" @change="apply()" class="mt-2 h-11 w-full rounded-xl border border-zinc-100 bg-zinc-50 px-3 text-sm text-zinc-900 shadow-sm outline-none focus:bg-white focus:ring-2 focus:ring-zinc-900/10">
										<option value="">All</option>
										<option value="S">S</option>
										<option value="M">M</option>
										<option value="L">L</option>
										<option value="XL">XL</option>
									</select>
								</div>
								<div>
									<label class="text-xs font-semibold uppercase tracking-[0.22em] text-zinc-400">Color</label>
									<select x-model="color" @change="apply()" class="mt-2 h-11 w-full rounded-xl border border-zinc-100 bg-zinc-50 px-3 text-sm text-zinc-900 shadow-sm outline-none focus:bg-white focus:ring-2 focus:ring-zinc-900/10">
										<option value="">All</option>
										<option value="Black">Black</option>
										<option value="White">White</option>
										<option value="Grey">Grey</option>
										<option value="Ivory">Ivory</option>
									</select>
								</div>
								<div>
									<label class="text-xs font-semibold uppercase tracking-[0.22em] text-zinc-400">Price</label>
									<select x-model="price" @change="apply()" class="mt-2 h-11 w-full rounded-xl border border-zinc-100 bg-zinc-50 px-3 text-sm text-zinc-900 shadow-sm outline-none focus:bg-white focus:ring-2 focus:ring-zinc-900/10">
										<option value="">All</option>
										<option value="0-15000">Rp 0 - 15rb</option>
										<option value="15000-25000">Rp 15rb - 25rb</option>
										<option value="25000-999999">Rp 25rb+</option>
									</select>
								</div>
							</div>
						</div>
					</aside>

					<div class="min-w-0">
						{cmsError ? (
							<div class="rounded-2xl border border-zinc-100 bg-white p-6 text-sm text-zinc-600 shadow-sm">{cmsError}</div>
						) : (
							<Fragment>
								<div class="flex items-end justify-between gap-6">
									<div>
										<h2 class="text-2xl font-semibold tracking-tight text-zinc-900">Avenue Collective</h2>
										<p class="mt-1 text-sm text-zinc-500">Monochrome staples, crafted for everyday wear.</p>
									</div>
									<div class="text-sm text-zinc-500"><span id="products-count">{productsForGrid.length}</span> products</div>
								</div>

								<div id="product-grid" class="mt-8 grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
									{productsForGrid.map((p, idx) => {
										const isSale = !!p.is_sale;
										const isNew = !!p.is_new;
										const isSold = typeof p.is_sold === 'boolean' ? p.is_sold : !((p.stock ?? 0) > 0);
										const showSale = isSale;
										const showNew = !showSale && isNew;
										const showSold = !showSale && !showNew && isSold;

										return (
											<article
												data-product-card
												data-title={p.title.toLowerCase()}
												data-category={p.category}
												data-new={String(isNew)}
												data-sale={String(isSale)}
												data-price={String(p.priceValue)}
												data-rating={String(p.ratingValue)}
												data-size={p.size}
												data-color={p.color}
												class="group flex h-full flex-col rounded-2xl border border-zinc-100 bg-white shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl"
											>
												<div class="p-5">
													<div class="relative mb-4 aspect-square overflow-hidden rounded-xl bg-zinc-100">
														<img
															src={p.imageUrl}
															alt={p.title}
															loading="lazy"
															class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
														/>

													{showNew ? (
														<span class="absolute left-3 top-3 rounded-full bg-black px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.22em] text-white">
															New
														</span>
													) : null}

													{showSale ? (
														<span class="absolute right-3 top-3 rounded-full bg-red-500 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.22em] text-white">
															Sale
														</span>
													) : null}

													{showSold ? (
														<span class="absolute right-3 top-3 rounded-full bg-amber-500 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.22em] text-white">
															Sold
														</span>
													) : null}

													<div class="pointer-events-none absolute inset-0 flex items-end justify-center bg-gradient-to-t from-black/35 via-black/0 to-black/0 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
														<div class="mb-4 rounded-full bg-white/90 px-4 py-2 text-xs font-semibold text-black shadow-sm">Quick View</div>
													</div>
													</div>

													<div class="flex flex-1 flex-col">
														<div class="text-xs font-semibold uppercase tracking-[0.22em] text-zinc-400">{p.category}</div>
														<div class="mt-1 min-h-[2.75rem] text-lg font-semibold leading-tight text-zinc-900 line-clamp-2">{p.title}</div>

														<div class="mt-2 mb-4 flex items-center justify-between gap-3">
																<div class="text-xl font-bold text-zinc-900">{p.price_formatted}</div>
															<div class="inline-flex items-center gap-1.5 text-sm text-zinc-500">
																<svg class="h-4 w-4 text-zinc-900" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
																	<path d="M12 17.27 18.18 21 16.54 13.97 22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21 12 17.27Z" />
																</svg>
																<span>{p.ratingValue.toFixed(1)}</span>
															</div>
														</div>

														<button
															type="button"
															class="relative mt-auto inline-flex w-full items-center justify-center overflow-hidden rounded-xl bg-zinc-900 py-3 text-sm font-medium text-white shadow-sm transition active:scale-95 hover:bg-zinc-800 disabled:cursor-not-allowed disabled:bg-zinc-300"
															data-cart-add
															data-cart-id={p.id}
															data-cart-title={p.title}
															aria-label={`Add ${p.title} to cart`}
															disabled={showSold}
														>
															Add to Cart
														</button>
													</div>
												</div>
											</article>
										);
									})}
								</div>

								<div id="products-empty" class="hidden rounded-2xl border border-zinc-100 bg-white p-10 shadow-sm">
									<div class="mx-auto flex max-w-md flex-col items-center text-center">
										<svg class="h-28 w-28 text-zinc-200" viewBox="0 0 120 120" fill="none" aria-hidden="true">
											<path d="M22 44c0-5.5 4.5-10 10-10h56c5.5 0 10 4.5 10 10v44c0 5.5-4.5 10-10 10H32c-5.5 0-10-4.5-10-10V44Z" fill="currentColor" />
											<path d="M38 40c0-9.4 7.6-17 17-17h10c9.4 0 17 7.6 17 17" stroke="#A1A1AA" stroke-width="6" stroke-linecap="round" />
											<path d="M42 62h36" stroke="#A1A1AA" stroke-width="6" stroke-linecap="round" />
										</svg>
										<div class="mt-5 text-lg font-semibold text-zinc-900">No products found</div>
										<div class="mt-2 text-sm text-zinc-500">Try adjusting your filters or search terms.</div>
									</div>
								</div>
							</Fragment>
						)}
					</div>
				</section>

				<div id="toast-root" class="pointer-events-none fixed bottom-6 left-1/2 z-50 w-[min(420px,calc(100vw-2rem))] -translate-x-1/2"></div>
		<script is:inline>
			window.fashionMarketplace = function fashionMarketplace({ initialSearch }) {
				return {
					search: String(initialSearch || ''),
					selectedCategories: [],
					activeFilters: { new: false, sale: false, rating: false },
					size: '',
					color: '',
					price: '',
					init() {
						this.apply();
					},
					togglePill(key) {
						this.activeFilters[key] = !this.activeFilters[key];
						this.apply();
					},
					reset() {
						this.search = '';
						this.selectedCategories = [];
						this.activeFilters = { new: false, sale: false, rating: false };
						this.size = '';
						this.color = '';
						this.price = '';
						this.apply();
					},
					apply() {
						const search = String(this.search || '').trim().toLowerCase();
						const selectedCategories = Array.isArray(this.selectedCategories) ? this.selectedCategories.map(String) : [];
						const showNew = !!this.activeFilters.new;
						const showSale = !!this.activeFilters.sale;
						const showRating = !!this.activeFilters.rating;
						const size = String(this.size || '').trim();
						const color = String(this.color || '').trim();
						const price = String(this.price || '').trim();

						let minPrice = null;
						let maxPrice = null;
						if (price.includes('-')) {
							const [a, b] = price.split('-');
							minPrice = Number(a) || null;
							maxPrice = Number(b) || null;
						}

						const cards = Array.from(document.querySelectorAll('[data-product-card]'));
						let shown = 0;

						for (const card of cards) {
							const title = String(card.getAttribute('data-title') || '');
							const cat = String(card.getAttribute('data-category') || '');
							const isNew = String(card.getAttribute('data-new') || '') === 'true';
							const isSale = String(card.getAttribute('data-sale') || '') === 'true';
							const cardRating = Number(card.getAttribute('data-rating') || '0');
							const cardSize = String(card.getAttribute('data-size') || '');
							const cardColor = String(card.getAttribute('data-color') || '');
							const cardPrice = Number(card.getAttribute('data-price') || '0');

							let visible = true;
							if (search && !title.includes(search)) visible = false;
							if (selectedCategories.length && !selectedCategories.includes(cat)) visible = false;
							if (showNew && !isNew) visible = false;
							if (showSale && !isSale) visible = false;
							if (showRating && cardRating < 4.5) visible = false;
							if (size && cardSize !== size) visible = false;
							if (color && cardColor !== color) visible = false;
							if (minPrice !== null && cardPrice < minPrice) visible = false;
							if (maxPrice !== null && cardPrice > maxPrice) visible = false;

							if (visible) {
								card.classList.remove('hidden');
								shown += 1;
							} else {
								card.classList.add('hidden');
							}
						}

						const countEl = document.getElementById('products-count');
						if (countEl) countEl.textContent = String(shown);

						const emptyEl = document.getElementById('products-empty');
						if (emptyEl) emptyEl.classList.toggle('hidden', shown !== 0);
					}
				};
			};
		</script>

		<script is:inline data-astro-rerun>
			(function () {
				const KEY = 'cart_items';
				const TOAST_ID = 'cart-toast';
				const readItems = () => {
					try {
						const raw = window.localStorage.getItem(KEY);
						if (!raw) return [];
						const arr = JSON.parse(raw);
						return Array.isArray(arr) ? arr : [];
					} catch {
						return [];
					}
				};
				const writeItems = (items) => {
					try {
						window.localStorage.setItem(KEY, JSON.stringify(items));
					} catch {}
				};
				const countItems = (items) => {
					let sum = 0;
					for (const it of items) {
						const q = Number(it?.qty ?? 0);
						if (Number.isFinite(q) && q > 0) sum += Math.trunc(q);
					}
					return sum;
				};

				const showToast = (message) => {
					const root = document.getElementById('toast-root');
					if (!root) return;

					const existing = document.getElementById(TOAST_ID);
					if (existing) existing.remove();

					const el = document.createElement('div');
					el.id = TOAST_ID;
					el.className = 'toast-enter rounded-2xl border border-zinc-200 bg-white/90 px-4 py-3 text-sm text-zinc-900 shadow-lg backdrop-blur-md';
					el.setAttribute('role', 'status');
					el.setAttribute('aria-live', 'polite');
					el.textContent = message;
					root.appendChild(el);

					requestAnimationFrame(() => {
						el.classList.add('toast-enter-active');
						el.classList.remove('toast-enter');
					});

					window.setTimeout(() => {
						el.classList.add('toast-leave-active');
						window.setTimeout(() => el.remove(), 200);
					}, 1600);
				};

				const addRipple = (button, ev) => {
					if (!(button instanceof HTMLElement)) return;
					const rect = button.getBoundingClientRect();
					const size = Math.max(rect.width, rect.height);
					const x = (ev?.clientX ?? rect.left + rect.width / 2) - rect.left - size / 2;
					const y = (ev?.clientY ?? rect.top + rect.height / 2) - rect.top - size / 2;

					const ripple = document.createElement('span');
					ripple.className = 'ripple';
					ripple.style.width = `${size}px`;
					ripple.style.height = `${size}px`;
					ripple.style.left = `${x}px`;
					ripple.style.top = `${y}px`;
					button.appendChild(ripple);
					window.setTimeout(() => ripple.remove(), 600);
				};

				document.addEventListener('click', (e) => {
					const t = e.target instanceof Element ? e.target.closest('[data-cart-add]') : null;
					if (!t) return;
					e.preventDefault();
					e.stopPropagation();
					addRipple(t, e);
					const id = Number(t.getAttribute('data-cart-id') || '0');
					if (!Number.isInteger(id) || id <= 0) return;

					const items = readItems();
					const idx = items.findIndex((x) => Number(x?.id) === id);
					if (idx >= 0) {
						const prev = Number(items[idx]?.qty ?? 0);
						items[idx] = { id, qty: Math.max(1, (Number.isFinite(prev) ? Math.trunc(prev) : 0) + 1) };
					} else {
						items.push({ id, qty: 1 });
					}
					writeItems(items);
					const count = countItems(items);
					window.dispatchEvent(new CustomEvent('cart:updated', { detail: { count } }));
					const title = String(t.getAttribute('data-cart-title') || '').trim();
					showToast(title ? `Added “${title}” to cart` : 'Added to cart');
				});
			})();
		</script>

		<script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
	</main>
</Layout>
