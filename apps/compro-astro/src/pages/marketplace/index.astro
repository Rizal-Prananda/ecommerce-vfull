---
import Layout from '../../layouts/Layout.astro';

type Product = {
	id: number;
	title: string;
	categoryId?: number;
	price: number;
	rating?: number;
	image?: string;
	location?: string;
};

type ProductView = Product & {
	category: string;
	spiceLevel: number;
	sold: number;
	imageUrl: string;
	ratingValue: number;
	isMock: boolean;
};

const CMS_URL = import.meta.env.PUBLIC_CMS_URL ?? 'http://127.0.0.1:8001';
const q = (Astro.url.searchParams.get('q') ?? '').trim();

let cmsError: string | null = null;
let products: Product[] = [];

try {
	const base = String(CMS_URL).replace(/\/$/, '');
	const url = `${base}/api/products${q ? `?q=${encodeURIComponent(q)}` : ''}`;
	const res = await fetch(url);
	if (!res.ok) throw new Error(`CMS error: ${res.status}`);
	const json = await res.json().catch(() => null);
	products = Array.isArray(json?.data) ? json.data : [];
} catch {
	cmsError = `Gagal mengambil data dari CMS (${CMS_URL}). Pastikan Laravel CMS sedang jalan.`;
}

function slugify(input: string) {
	return input
		.toLowerCase()
		.trim()
		.replace(/[^a-z0-9]+/g, '-')
		.replace(/(^-|-$)/g, '');
}

function formatRupiah(v: number) {
	return new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', maximumFractionDigits: 0 }).format(v);
}

const categories = ['Seblak', 'Mie', 'Bakso', 'Cemilan', 'Minuman'];

function pickCategory(p: Product) {
	if (typeof p.categoryId === 'number' && Number.isFinite(p.categoryId)) {
		return categories[Math.abs(p.categoryId) % categories.length] ?? 'Seblak';
	}
	return categories[p.id % categories.length] ?? 'Seblak';
}

function spiceLevelFrom(p: Product) {
	return p.id % 11;
}

function soldFrom(p: Product) {
	return 20 + ((p.id * 37) % 800);
}

function ratingFrom(p: Product) {
	const v = typeof p.rating === 'number' && Number.isFinite(p.rating) ? p.rating : 0;
	return Math.max(0, Math.min(5, v));
}

const productsView: ProductView[] = products.map((p) => {
	const spiceLevel = spiceLevelFrom(p);
	const category = pickCategory(p);
	const ratingValue = ratingFrom(p);
	const seed = encodeURIComponent(String(p.id));

	return {
		...p,
		spiceLevel,
		category,
		sold: soldFrom(p),
		ratingValue,
		imageUrl: p.image ?? `https://picsum.photos/seed/seblak-${seed}/600/450`,
		isMock: false,
	};
});

function makeMockProduct(index: number): ProductView {
	const id = 100000 + index;
	const titlePool = [
		'Seblak Ceker Super Pedas',
		'Seblak Komplit Baso + Sosis',
		'Seblak Kerupuk Bandung',
		'Mie Seblak Level Neraka',
		'Seblak Tulang Extra',
		'Bakso Aci Kuah Pedas',
		'Cireng Bumbu Rujak',
		'Es Teh Lemon Segar',
		'Seblak Keju Mozzarella',
		'Seblak Seafood Mix',
	];
	const title = titlePool[index % titlePool.length] ?? `Produk ${id}`;
	const category = categories[index % categories.length] ?? 'Seblak';
	const spiceLevel = index % 11;
	const price = 8000 + ((index * 1750) % 32000);
	const ratingValue = Number(((3.8 + ((index % 12) / 20)) % 5).toFixed(1));
	const sold = 50 + ((index * 29) % 1200);
	const seed = encodeURIComponent(String(id));

	return {
		id,
		title,
		price,
		category,
		spiceLevel,
		sold,
		ratingValue,
		imageUrl: `https://picsum.photos/seed/seblak-mock-${seed}/600/450`,
		isMock: true,
	};
}

const desiredGridCount = 15;
const productsForGrid: ProductView[] = [...productsView];
for (let i = 0; productsForGrid.length < desiredGridCount; i += 1) {
	productsForGrid.push(makeMockProduct(i));
}

const recommended = productsForGrid.slice(0, 10);

const desiredCatalogCount = 30;
const productsForCatalog: ProductView[] = [...productsForGrid];
for (let i = 0; productsForCatalog.length < desiredCatalogCount; i += 1) {
	productsForCatalog.push(makeMockProduct(100 + i));
}

const productsByCategory: Record<string, ProductView[]> = Object.fromEntries(
	categories.map((c) => [c, productsForCatalog.filter((p) => p.category === c)])
);
---

<Layout title="Marketplace">
	<style>
		.no-scrollbar::-webkit-scrollbar { display: none; }
		.no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
	</style>

	<main class="bg-slate-50">
		<div class="mx-auto w-full max-w-6xl px-4 pt-10 pb-16">
			<div class="flex flex-col gap-6">
				<div class="flex flex-col gap-2">
					<h1 class="text-3xl font-semibold tracking-tight text-slate-900">Marketplace Seblak</h1>
					<p class="text-sm text-slate-600">Jajanan pedas, seblak, dan makanan favorit kamu.</p>
				</div>

				<div
					x-data="marketplaceFilterBar({ initialSearch: $el.getAttribute('data-initial-search') || '' })"
					x-init="init()"
					data-initial-search={q}
					class="sticky top-[72px] z-20 -mx-4 border-y border-slate-200 bg-white/85 px-4 py-4 backdrop-blur-md"
				>
					<div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
						<div class="flex flex-1 flex-col gap-3 sm:flex-row sm:items-center">
							<div class="relative w-full sm:flex-1">
								<svg class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-slate-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
									<path d="M21 21l-4.3-4.3" />
									<circle cx="11" cy="11" r="7" />
								</svg>
								<input
									x-ref="search"
									x-model="search"
									@input.debounce.150ms="apply()"
									placeholder="Cari seblak, topping, minuman..."
									class="h-11 w-full rounded-lg border-0 bg-slate-100 px-10 text-sm text-slate-900 shadow-sm outline-none placeholder:text-slate-400 focus:ring-2 focus:ring-slate-900/10"
								/>
							</div>

							<div class="flex items-center gap-2">
								<button
									type="button"
									@click="togglePill('pedas')"
									class="inline-flex h-10 items-center gap-2 rounded-lg px-3 text-sm font-semibold shadow-sm transition"
									:class="pedas ? 'bg-slate-900 text-white' : 'bg-slate-100 text-slate-700 hover:bg-slate-200'"
								>
									<span aria-hidden="true">🔥</span>
									Pedas
								</button>
								<button
									type="button"
									@click="togglePill('promo')"
									class="inline-flex h-10 items-center gap-2 rounded-lg px-3 text-sm font-semibold shadow-sm transition"
									:class="promo ? 'bg-slate-900 text-white' : 'bg-slate-100 text-slate-700 hover:bg-slate-200'"
								>
									% Promo
								</button>
								<button
									type="button"
									@click="togglePill('rating')"
									class="inline-flex h-10 items-center gap-2 rounded-lg px-3 text-sm font-semibold shadow-sm transition"
									:class="rating45 ? 'bg-slate-900 text-white' : 'bg-slate-100 text-slate-700 hover:bg-slate-200'"
								>
									<span aria-hidden="true">⭐</span>
									4.5+
								</button>
							</div>
						</div>

						<div class="relative">
							<button
								type="button"
								@click="open = !open"
								class="inline-flex h-10 items-center justify-center gap-2 rounded-lg bg-slate-100 px-3 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-200"
								:aria-expanded="open"
							>
								Filter
								<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
									<path d="M6 9l6 6 6-6" />
								</svg>
							</button>

							<div
								x-show="open"
								x-cloak
								@click.outside="open = false"
								class="absolute right-0 z-30 mt-2 w-72 rounded-xl border border-slate-200 bg-white p-3 shadow-lg"
							>
								<div class="grid gap-3">
									<div>
										<label class="text-xs font-semibold text-slate-700">Kategori</label>
										<select
											x-model="category"
											@change="apply()"
											class="mt-1.5 h-10 w-full rounded-lg border-0 bg-slate-100 px-3 text-sm text-slate-900 shadow-sm outline-none focus:ring-2 focus:ring-slate-900/10"
										>
											<option value="">Semua</option>
											{categories.map((c) => (
												<option value={c}>{c}</option>
											))}
										</select>
									</div>

									<div>
										<label class="text-xs font-semibold text-slate-700">Harga</label>
										<select
											x-model="priceRange"
											@change="apply()"
											class="mt-1.5 h-10 w-full rounded-lg border-0 bg-slate-100 px-3 text-sm text-slate-900 shadow-sm outline-none focus:ring-2 focus:ring-slate-900/10"
										>
											<option value="">Semua</option>
											<option value="0-10000">&lt; Rp 10rb</option>
											<option value="10000-20000">Rp 10rb - 20rb</option>
											<option value="20000-35000">Rp 20rb - 35rb</option>
											<option value="35000-999999">&gt; Rp 35rb</option>
										</select>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>

				{productsView.length ? (
					<>
						<section class="mt-2">
							<div class="mb-3 flex items-center justify-between gap-3">
								<div>
									<div class="text-lg font-semibold text-slate-900">Rekomendasi</div>
									<div class="mt-0.5 text-sm text-slate-600">Pilihan terbaik untuk kamu hari ini.</div>
								</div>
								<div class="flex items-center gap-2">
									<button
										type="button"
										class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-slate-200 bg-white text-slate-700 shadow-sm hover:bg-slate-50"
										onclick="scrollSlider('rekomendasi-slider', -1)"
										aria-label="Scroll left"
									>
										<svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
											<path d="M15 18l-6-6 6-6" />
										</svg>
									</button>
									<button
										type="button"
										class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-slate-200 bg-white text-slate-700 shadow-sm hover:bg-slate-50"
										onclick="scrollSlider('rekomendasi-slider', 1)"
										aria-label="Scroll right"
									>
										<svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
											<path d="M9 18l6-6-6-6" />
										</svg>
									</button>
								</div>
							</div>

							<div id="rekomendasi-slider" class="no-scrollbar flex gap-3 overflow-x-auto pb-1">
								{recommended.map((p) => (
									<a
										href={p.isMock ? '#' : `/marketplace/${p.id}-${slugify(p.title)}`}
										class={`group w-52 shrink-0 rounded-xl border border-slate-200/80 bg-white shadow-sm transition hover:-translate-y-0.5 hover:shadow-md ${p.isMock ? 'cursor-default' : ''}`}
									>
										<div class="relative h-32 overflow-hidden rounded-t-xl bg-slate-100">
											<img
												src={p.imageUrl}
												alt={p.title}
												loading="lazy"
												class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.03]"
											/>
											<div class="absolute left-2 top-2 inline-flex items-center rounded-md bg-red-500/90 px-2 py-1 text-[10px] font-bold text-white">
												Level {p.spiceLevel}
											</div>
										</div>
										<div class="p-2.5">
											<div class="h-4 line-clamp-1 text-xs font-semibold text-slate-900">{p.title}</div>
											<div class="mt-1 flex items-center justify-between text-[11px] text-slate-500">
												<div class="inline-flex items-center gap-1">
													<svg class="h-2.5 w-2.5 text-amber-500" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
														<path d="M12 17.27 18.18 21 16.54 13.97 22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21 12 17.27Z" />
													</svg>
													<span class="font-semibold text-slate-700">{p.ratingValue ? p.ratingValue.toFixed(1) : '—'}</span>
													<span class="text-slate-300">•</span>
													<span>{p.sold} terjual</span>
												</div>
											</div>
											<div class="mt-2 flex items-center justify-between gap-2">
												<div class="text-sm font-bold text-slate-900">{formatRupiah(p.price)}</div>
												<button
													type="button"
													class="inline-flex items-center justify-center rounded-md bg-slate-900 p-1.5 text-white shadow-sm hover:bg-slate-800"
													data-cart-add
													data-cart-id={p.id}
													aria-label="Add to cart"
												>
													<svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
														<path d="M12 5v14" />
														<path d="M5 12h14" />
													</svg>
												</button>
											</div>
										</div>
									</a>
								))}
							</div>
						</section>

						<section class="mt-8">
							<div class="mb-3 flex items-center justify-between gap-3">
								<div>
									<div class="text-lg font-semibold text-slate-900">Produk per Kategori</div>
									<div class="mt-0.5 text-sm text-slate-600">
										<span id="products-count">{productsForCatalog.length}</span> produk ditampilkan
									</div>
								</div>
							</div>

							<div id="catalog" class="space-y-8">
								{categories.map((cat) => {
									const list = productsByCategory[cat] ?? [];
									const sliderId = `cat-slider-${cat.toLowerCase()}`;

									return (
										<section class="category-section" data-category={cat}>
											<div class="mb-3 flex items-center justify-between gap-3">
												<div class="min-w-0">
													<div class="text-base font-semibold text-slate-900">{cat}</div>
													<div class="mt-0.5 text-xs text-slate-600">
														<span class="category-count" data-category-count={cat}>{list.length}</span> item
													</div>
												</div>
												<div class="flex items-center gap-2">
													<button
														type="button"
														class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-slate-200 bg-white text-slate-700 shadow-sm hover:bg-slate-50"
														onclick={`scrollSlider('${sliderId}', -1)`}
														aria-label={`Scroll left ${cat}`}
													>
														<svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
															<path d="M15 18l-6-6 6-6" />
														</svg>
													</button>
													<button
														type="button"
														class="inline-flex h-10 w-10 items-center justify-center rounded-xl border border-slate-200 bg-white text-slate-700 shadow-sm hover:bg-slate-50"
														onclick={`scrollSlider('${sliderId}', 1)`}
														aria-label={`Scroll right ${cat}`}
													>
														<svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
															<path d="M9 18l6-6-6-6" />
														</svg>
													</button>
												</div>
											</div>

											<div id={sliderId} class="no-scrollbar flex gap-3 overflow-x-auto pb-1">
												{list.map((p) => (
													<a
														href={p.isMock ? '#' : `/marketplace/${p.id}-${slugify(p.title)}`}
														class={`product-card group w-52 shrink-0 rounded-xl border border-slate-200/80 bg-white shadow-sm transition hover:-translate-y-0.5 hover:shadow-md ${p.isMock ? 'cursor-default' : ''}`}
														data-title={p.title.toLowerCase()}
														data-category={p.category}
														data-level={String(p.spiceLevel)}
														data-promo={String(p.id % 4 === 0)}
														data-price={String(p.price)}
														data-rating={String(p.ratingValue)}
													>
														<div class="relative h-28 overflow-hidden rounded-t-xl bg-slate-100">
															<img
																src={p.imageUrl}
																alt={p.title}
																loading="lazy"
																class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.03]"
															/>
															<div class="absolute left-2 top-2 inline-flex items-center rounded-md bg-red-500/90 px-2 py-1 text-[10px] font-bold text-white">
																Level {p.spiceLevel}
															</div>
														</div>
														<div class="p-2.5">
															<div class="h-4 line-clamp-1 text-xs font-semibold text-slate-900">{p.title}</div>
															<div class="mt-1 flex items-center justify-between text-[11px] text-slate-500">
																<div class="inline-flex items-center gap-1">
																	<svg class="h-2.5 w-2.5 text-amber-500" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
																		<path d="M12 17.27 18.18 21 16.54 13.97 22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21 12 17.27Z" />
																	</svg>
																	<span class="font-semibold text-slate-700">{p.ratingValue ? p.ratingValue.toFixed(1) : '—'}</span>
																	<span class="text-slate-300">•</span>
																	<span>{p.sold} terjual</span>
																</div>
															</div>
															<div class="mt-2 flex items-center justify-between gap-2">
																<div class="text-sm font-bold text-slate-900">{formatRupiah(p.price)}</div>
																<button
																	type="button"
																	class="inline-flex items-center justify-center rounded-md bg-slate-900 p-1.5 text-white shadow-sm hover:bg-slate-800"
																	data-cart-add
																	data-cart-id={p.id}
																	aria-label="Add to cart"
																>
																	<svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
																		<path d="M12 5v14" />
																		<path d="M5 12h14" />
																	</svg>
																</button>
															</div>
														</div>
													</a>
												))}
											</div>
										</section>
									);
								})}
							</div>

							<div id="products-empty" class="hidden rounded-xl border border-slate-200 bg-white p-6 text-sm text-slate-600 shadow-sm">
								Tidak ada produk yang cocok dengan filter.
							</div>
						</section>
					</>
				) : cmsError ? (
					<div class="rounded-xl border border-amber-200 bg-amber-50 p-6 text-sm text-amber-900 shadow-sm">{cmsError}</div>
				) : (
					<div class="rounded-xl border border-slate-200 bg-white p-6 text-sm text-slate-600 shadow-sm">
						{q ? `Produk "${q}" tidak ditemukan.` : 'Belum ada produk.'}
					</div>
				)}
			</div>
		</div>

		<script is:inline>
			function scrollSlider(id, dir) {
				const el = document.getElementById(id);
				if (!el) return;
				const step = Math.max(210, Math.floor(el.clientWidth * 0.8));
				el.scrollBy({ left: dir * step, behavior: 'smooth' });
			}
			function parseNumber(value) {
				const n = Number(String(value || '').trim());
				return Number.isFinite(n) ? n : null;
			}

			window.marketplaceFilterBar = function marketplaceFilterBar({ initialSearch }) {
				return {
					open: false,
					search: String(initialSearch || ''),
					category: '',
					priceRange: '',
					pedas: false,
					promo: false,
					rating45: false,
					init() {
						this.apply();
					},
					togglePill(key) {
						if (key === 'pedas') this.pedas = !this.pedas;
						if (key === 'promo') this.promo = !this.promo;
						if (key === 'rating') this.rating45 = !this.rating45;
						this.apply();
					},
					apply() {
						const search = String(this.search || '').trim().toLowerCase();
						const category = String(this.category || '').trim();
						const pedas = !!this.pedas;
						const promo = !!this.promo;
						const rating45 = !!this.rating45;
						const priceRange = String(this.priceRange || '').trim();

						let priceMin = null;
						let priceMax = null;
						if (priceRange.includes('-')) {
							const [a, b] = priceRange.split('-');
							priceMin = parseNumber(a);
							priceMax = parseNumber(b);
						}

						const cards = Array.from(document.querySelectorAll('#catalog .product-card'));
						let shown = 0;
						for (const card of cards) {
							const title = String(card.getAttribute('data-title') || '');
							const cat = String(card.getAttribute('data-category') || '');
							const level = parseNumber(card.getAttribute('data-level')) ?? 0;
							const price = parseNumber(card.getAttribute('data-price')) ?? 0;
							const rating = parseNumber(card.getAttribute('data-rating')) ?? 0;
							const isPromo = String(card.getAttribute('data-promo') || '') === 'true';

							let ok = true;
							if (search && !title.includes(search)) ok = false;
							if (category && cat !== category) ok = false;
							if (pedas && level < 7) ok = false;
							if (promo && !isPromo) ok = false;
							if (rating45 && rating < 4.5) ok = false;
							if (priceMin !== null && price < priceMin) ok = false;
							if (priceMax !== null && price > priceMax) ok = false;

							if (ok) {
								card.classList.remove('hidden');
								shown += 1;
							} else {
								card.classList.add('hidden');
							}
						}

						const countEl = document.getElementById('products-count');
						if (countEl) countEl.textContent = String(shown);

						const perCat = new Map();
						for (const card of cards) {
							if (card.classList.contains('hidden')) continue;
							const cat = String(card.getAttribute('data-category') || '');
							perCat.set(cat, (perCat.get(cat) ?? 0) + 1);
						}
						for (const el of Array.from(document.querySelectorAll('.category-count'))) {
							const cat = String(el.getAttribute('data-category-count') || '');
							el.textContent = String(perCat.get(cat) ?? 0);
						}

						const emptyEl = document.getElementById('products-empty');
						if (emptyEl) emptyEl.classList.toggle('hidden', shown !== 0);
					}
				};
			};
		</script>

		<script is:inline data-astro-rerun>
			(function () {
				const KEY = 'cart_items';
				const readItems = () => {
					try {
						const raw = window.localStorage.getItem(KEY);
						if (!raw) return [];
						const arr = JSON.parse(raw);
						return Array.isArray(arr) ? arr : [];
					} catch {
						return [];
					}
				};
				const writeItems = (items) => {
					try {
						window.localStorage.setItem(KEY, JSON.stringify(items));
					} catch {}
				};
				const countItems = (items) => {
					let sum = 0;
					for (const it of items) {
						const q = Number(it?.qty ?? 0);
						if (Number.isFinite(q) && q > 0) sum += Math.trunc(q);
					}
					return sum;
				};

				document.addEventListener('click', (e) => {
					const t = e.target instanceof Element ? e.target.closest('[data-cart-add]') : null;
					if (!t) return;
					e.preventDefault();
					e.stopPropagation();
					const id = Number(t.getAttribute('data-cart-id') || '0');
					if (!Number.isInteger(id) || id <= 0) return;

					const items = readItems();
					const idx = items.findIndex((x) => Number(x?.id) === id);
					if (idx >= 0) {
						const prev = Number(items[idx]?.qty ?? 0);
						items[idx] = { id, qty: Math.max(1, (Number.isFinite(prev) ? Math.trunc(prev) : 0) + 1) };
					} else {
						items.push({ id, qty: 1 });
					}
					writeItems(items);
					const count = countItems(items);
					window.dispatchEvent(new CustomEvent('cart:updated', { detail: { count } }));
				});
			})();
		</script>

		<script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
	</main>
</Layout>
